<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>NickERP.Inspection.Core</RootNamespace>
    <AssemblyName>NickERP.Inspection.Core</AssemblyName>
    <Description>NickERP Inspection v2 — Core domain. Vendor-neutral entities (Location, Station, ScannerDeviceInstance, ExternalSystemInstance, ExternalSystemBinding, etc.). Carries no vendor names; ICUMS/FS6000/etc. live in the plugin adapters.</Description>
    <Version>0.1.0</Version>
    <Company>Nick TC-Scan Ltd</Company>
    <Product>NICKSCAN ERP SOLUTION</Product>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\platform\NickERP.Platform.Tenancy\NickERP.Platform.Tenancy.csproj" />
  </ItemGroup>

</Project>
