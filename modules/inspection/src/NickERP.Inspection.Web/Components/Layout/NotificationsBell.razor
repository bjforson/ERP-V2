@*
 * Sprint 8 P3 — wraps the shared Web.Shared NotificationBell with a
 * 30-second polling timer that refreshes the unread count from the
 * AuditDbContext. Designed to slot into TopNav's NotificationsSlot.
 *
 * Sprint 35 / B8.1 — the unread count read is now routed through
 * NotificationInboxService.UnreadCountAsync so the bell + the inbox
 * page share one COUNT path. The service still hits the partial
 * ix_notifications_user_unread index so the call stays O(1) cheap.
 *
 * Keeps it server-side: this is a Blazor Server app and the audit
 * context is already wired into DI via the service, so no HTTP
 * indirection is needed for the count read. The /api/notifications
 * endpoints are still the canonical interface — they handle the
 * mark-as-read calls for any future non-Blazor UI.
 *@
@using System.Security.Claims
@using NickERP.Inspection.Web.Services
@using NickERP.Platform.Identity.Auth
@inject NotificationInboxService Inbox
@inject AuthenticationStateProvider AuthState
@implements IDisposable

<a href="/notifications" class="nickerp-bell-link" aria-label="Open notifications">
    <NickERP.Platform.Web.Shared.Components.NotificationBell UnreadCount="_unreadCount" />
</a>

@code {
    private int _unreadCount;
    private System.Threading.Timer? _timer;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        // 30s poll — cheap (one indexed COUNT) and matches the PLAN spec.
        _timer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await RefreshAsync();
                    StateHasChanged();
                });
            }
            catch
            {
                // Best-effort — a failed poll just keeps the last value.
            }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task RefreshAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var raw = auth.User.FindFirst(NickErpClaims.Id)?.Value
                  ?? auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(raw) || !Guid.TryParse(raw, out var userId))
        {
            _unreadCount = 0;
            return;
        }

        // Sprint 35 / B8.1 — wire bell to NotificationInboxService so the
        // bell + page share the same COUNT path. RLS narrows by tenant +
        // user (FU-userid); the service threads userId through as a
        // defence-in-depth guard.
        _unreadCount = await Inbox.UnreadCountAsync(userId);
    }

    /// <inheritdoc />
    public void Dispose()
    {
        _timer?.Dispose();
    }
}
