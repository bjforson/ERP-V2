@inherits LayoutComponentBase

@* Sprint 29 — three-module co-deploy chrome. SharedHeader sits above
   the legacy TopNav so the suite reads as one product (back-to-launcher
   link + identity dropdown). The legacy TopNav stays for now — its
   notifications-bell + AppSwitcher slots are too valuable to drop in
   one sprint, and a future iteration can fold them into the shared
   chrome's slots. SharedFooter anchors the bottom with the version
   badge + portal link. *@
<SharedHeader ModuleId="inspection" />

<TopNav AppName="Inspection v2" AppHomeHref="/" SearchEnabled="false">
    <NotificationsSlot>
        @* Sprint 8 P3 — overrides the placeholder shared bell with one
           backed by audit.notifications. Shows unread count, links to
           /notifications. *@
        <NotificationsBell />
    </NotificationsSlot>
</TopNav>

<div class="inspection-shell">
    <nav class="inspection-sidenav">
        <NavLink href="/" Match="NavLinkMatch.All">Overview</NavLink>
        <div class="inspection-sidenav-section">Operations</div>
        <NavLink href="/cases">Cases</NavLink>
        <NavLink href="/notifications">Notifications</NavLink>
        <div class="inspection-sidenav-section">Setup</div>
        <NavLink href="/locations">Locations</NavLink>
        <NavLink href="/stations">Stations</NavLink>
        <NavLink href="/scanners">Scanners</NavLink>
        <NavLink href="/external-systems">External systems</NavLink>
        <NavLink href="/location-assignments">User assignments</NavLink>
        <NavLink href="/plugins">Plugins</NavLink>
        <div class="inspection-sidenav-section">Admin</div>
        <NavLink href="/admin/analysis-services">Analysis services</NavLink>
        <NavLink href="/admin/posthoc-outcomes">Post-hoc outcomes</NavLink>
        <NavLink href="/admin/thresholds">Threshold calibration</NavLink>
        <div class="inspection-sidenav-section">Diagnostics</div>
        <NavLink href="/perf">Acceptance bars</NavLink>
    </nav>

    <main class="inspection-main">
        @Body
    </main>
</div>

<SharedFooter />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
