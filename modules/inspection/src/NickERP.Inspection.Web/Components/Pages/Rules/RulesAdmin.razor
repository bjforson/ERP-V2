@page "/admin/rules"
@* Sprint 28 / B4 Phase C — admin index for vendor-neutral validation rules.
   Lists every registered IValidationRule with the current tenant's enabled
   flag + recent failure counts. Toggling Enabled persists to
   tenancy.tenant_validation_rule_settings via RulesAdminService and emits
   an inspection.validation_rule.toggled audit event so the trail of
   who-disabled-what survives.

   Sprint 37 / FU-rules-admin-role — Inspection.RulesAdmin is the
   dedicated role for this page; Inspection.Admin is kept in the
   any-of list so existing generic-admin grants continue to work
   without a per-grant migration. Role constants live in
   platform/NickERP.Platform.Identity/Auth/InspectionRoles.cs. *@
@attribute [Authorize(Roles = "Inspection.RulesAdmin,Inspection.Admin")]
@using System.Security.Claims
@using NickERP.Inspection.Web.Services
@using NickERP.Platform.Tenancy
@inject RulesAdminService AdminService
@inject ITenantContext Tenant
@inject AuthenticationStateProvider AuthState

<PageTitle>Validation rules — Inspection v2</PageTitle>

<header class="inspection-page-header">
    <div>
        <h1>Validation rules</h1>
        <p class="inspection-page-subtitle">
            Vendor-neutral validation engine (Sprint 28 / B4). Toggle a rule
            off to silence it for this tenant. Drill into a row to see
            recent failures.
        </p>
        <p class="inspection-page-subtitle">
            <strong>Strict mode</strong> (Sprint 48 / Phase A) — when enabled,
            submission throws if the engine reports any error-severity
            outcome on the most recent run. Default off; flip per tenant
            via the toggle below. The change is audited via
            <code>nickerp.inspection.validation.strict_mode_changed</code>.
        </p>
    </div>
</header>

@if (!Tenant.IsResolved)
{
    <p class="inspection-empty">Tenant context is not resolved. Sign out and back in.</p>
}
else if (_rows is null)
{
    <p>Loading…</p>
}
else
{
    <section class="inspection-section">
        @if (!string.IsNullOrEmpty(_message))
        {
            <p class="inspection-form-message">@_message</p>
        }

        @* Sprint 48 / Phase A — strict-mode toggle. Lives at the top of
           the page so the audit trail of who-flipped-what stays in plain
           sight while the analyst is reviewing rule rows. *@
        <div class="inspection-form-row" data-testid="strict-mode-row">
            <span class="inspection-badge @(_strictMode ? "inspection-badge-warning" : "inspection-badge-good")">
                Strict mode: @(_strictMode ? "ON" : "OFF")
            </span>
            <button type="button"
                    class="inspection-button"
                    data-testid="strict-mode-toggle"
                    @onclick="ToggleStrictModeAsync">
                @(_strictMode ? "Disable strict mode" : "Enable strict mode")
            </button>
        </div>

        @if (_rows.Count == 0)
        {
            <p class="inspection-empty">No validation rules are registered. Confirm <code>AddNickErpInspectionValidation()</code> ran during host startup.</p>
        }
        else
        {
            <table class="inspection-table">
                <thead>
                    <tr>
                        <th>Rule</th>
                        <th>Description</th>
                        <th>Enabled</th>
                        <th>Recent failures (7d)</th>
                        <th>Last toggled</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _rows)
                    {
                        <tr>
                            <td><code>@r.RuleId</code></td>
                            <td>@r.Description</td>
                            <td>
                                @if (r.Enabled)
                                {
                                    <span class="inspection-badge inspection-badge-good">Enabled</span>
                                }
                                else
                                {
                                    <span class="inspection-badge inspection-badge-warning">Disabled</span>
                                }
                            </td>
                            <td>@r.RecentFailureCount</td>
                            <td>
                                @if (r.LastUpdatedAt is { } t)
                                {
                                    <span title="@t.ToString("O")">@t.ToString("yyyy-MM-dd HH:mm")</span>
                                }
                                else
                                {
                                    <span class="inspection-empty">—</span>
                                }
                            </td>
                            <td>
                                <a class="inspection-button" href="/admin/rules/@r.RuleId">Open</a>
                                <button type="button"
                                        class="inspection-button"
                                        @onclick="() => ToggleAsync(r.RuleId, !r.Enabled)">
                                    @(r.Enabled ? "Disable" : "Enable")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private List<RuleAdminRow>? _rows;
    private string? _message;
    // Sprint 48 / Phase A — local view of the per-tenant strict-mode flag.
    // Loaded in OnInitializedAsync; mutated by ToggleStrictModeAsync.
    private bool _strictMode;

    protected override async Task OnInitializedAsync()
    {
        if (!Tenant.IsResolved) return;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        if (!Tenant.IsResolved) return;
        var rows = await AdminService.ListRulesAsync(Tenant.TenantId);
        _rows = rows.ToList();
        _strictMode = await AdminService.GetStrictModeAsync(Tenant.TenantId);
    }

    private async Task ToggleAsync(string ruleId, bool enabled)
    {
        if (!Tenant.IsResolved) return;
        var actor = await ResolveActorAsync();
        try
        {
            await AdminService.SetRuleEnabledAsync(Tenant.TenantId, ruleId, enabled, actor);
            _message = $"Rule '{ruleId}' is now {(enabled ? "enabled" : "disabled")}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _message = $"Toggle failed: {ex.Message}";
        }
    }

    private async Task ToggleStrictModeAsync()
    {
        if (!Tenant.IsResolved) return;
        var actor = await ResolveActorAsync();
        var newValue = !_strictMode;
        try
        {
            await AdminService.SetStrictModeAsync(Tenant.TenantId, newValue, actor);
            _strictMode = newValue;
            _message = $"Strict mode is now {(newValue ? "ON" : "OFF")} for this tenant.";
        }
        catch (Exception ex)
        {
            _message = $"Strict-mode toggle failed: {ex.Message}";
        }
    }

    private async Task<Guid?> ResolveActorAsync()
    {
        try
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            var idClaim = state.User?.FindFirst("nickerp:id")?.Value;
            return Guid.TryParse(idClaim, out var g) ? g : null;
        }
        catch (InvalidOperationException)
        {
            return null;
        }
    }
}
