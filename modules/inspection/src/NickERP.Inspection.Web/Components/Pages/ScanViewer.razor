@page "/cases/{CaseId:guid}/scans/{ScanId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using NickERP.Inspection.Core.Entities
@using NickERP.Inspection.Database
@using NickERP.Inspection.Web.Services
@inject InspectionDbContext Db
@inject AnalystAnnotationService Annotations
@inject IJSRuntime JS
@inject ILogger<ScanViewer> Logger
@implements IAsyncDisposable

@*
    Sprint V4 — analyst W/L viewer (W/L sliders + pixel probe + ROI).
    Sprint 20 / B1.2 — annotation tool (Finding-backed).
    Sprint 20 / B1.3 — multi-scan navigation + predictive prefetch.

    Loads the scan's primary ScanArtifact, hands the pre-rendered preview
    PNG endpoint URL to the JS interop module (wwwroot/js/scan-viewer.js),
    and surfaces window/level sliders, a pixel probe, and an ROI inspector
    against the original 8-bit ImageData.

    B1.2 adds an annotate tool: switching modes routes mouseup through the
    JS finalizeAnnotation helper, the result is POSTed to
    /api/inspection/annotations as a Finding row, and persisted
    annotations are fetched on init + re-overlaid on every redraw.

    B1.3 adds a scan-pager (prev / next within the same case) plus
    predictive prefetch — when the operator opens scan N, we prime the
    HTTP cache for scan N+1's preview so the next click lands without a
    round-trip.

    Out of scope: 16-bit raw channel viewer (separate work item in the
    IMAGE-ANALYSIS-MODERNIZATION track). This page consumes only what
    the pre-render service already produces.
*@

<PageTitle>Scan viewer — Inspection v2</PageTitle>

@if (_case is null || _scan is null)
{
    <p>Loading…</p>
}
else
{
    <header class="inspection-page-header">
        <div>
            <h1>Scan <code>@_scan.Id.ToString()[..8]</code> &nbsp;
                <span class="inspection-pill-state is-@_case.State.ToString().ToLowerInvariant()">@_case.State</span>
            </h1>
            <p class="inspection-page-subtitle">
                <a href="/cases/@CaseId">← back to case @_case.SubjectIdentifier</a> &nbsp;•&nbsp;
                @_case.SubjectType <code>@_case.SubjectIdentifier</code> &nbsp;•&nbsp;
                captured @_scan.CapturedAt.ToString("yyyy-MM-dd HH:mm:ss") &nbsp;•&nbsp;
                @(_scannerName ?? "?") &nbsp;•&nbsp;
                @(_locationCode ?? "?")
            </p>
            @if (_caseScanIds.Count > 1)
            {
                <p class="inspection-scan-pager">
                    @if (_prevScanId is { } prev)
                    {
                        <a class="inspection-button" href="/cases/@CaseId/scans/@prev">← Prev scan</a>
                    }
                    else
                    {
                        <span class="inspection-button is-disabled">← Prev scan</span>
                    }
                    <span class="inspection-scan-pager-pos">Scan @_scanPosition of @_caseScanIds.Count</span>
                    @if (_nextScanId is { } next)
                    {
                        <a class="inspection-button" href="/cases/@CaseId/scans/@next">Next scan →</a>
                    }
                    else
                    {
                        <span class="inspection-button is-disabled">Next scan →</span>
                    }
                </p>
            }
        </div>
    </header>

    <section class="inspection-section">
        @if (_artifact is null)
        {
            <div class="inspection-card">
                <p class="inspection-empty">
                    No primary artifact attached to this scan yet — the ingestion pipeline may
                    still be writing. Try again in a few seconds.
                </p>
            </div>
        }
        else
        {
            <div class="viewer-shell">
                <div class="viewer-canvas-wrap">
                    @* Mouse handlers stay raw DOM events — bunit can render the markup
                       without an IJSRuntime fully in place; the interop calls run only
                       in OnAfterRenderAsync(firstRender). *@
                    <canvas @ref="_canvasRef"
                            class="viewer-canvas @(_tool == ToolMode.Annotate ? "is-annotating" : "")"
                            @onmousemove="OnMouseMove"
                            @onmousedown="OnMouseDown"
                            @onmouseup="OnMouseUp"
                            @onmouseleave="OnMouseLeave"></canvas>
                    @if (_loadFailed)
                    {
                        <p class="inspection-empty">
                            No preview yet — the pre-render worker hasn't reached this artifact.
                            Try again in a few seconds.
                        </p>
                    }
                </div>

                <aside class="viewer-controls">
                    <div class="inspection-card">
                        <h2 class="inspection-card-title">Tool</h2>
                        <div class="inspection-button-row">
                            <button class="inspection-button @(_tool == ToolMode.Inspect ? "inspection-button-primary" : "")"
                                    @onclick="@(() => SetToolAsync(ToolMode.Inspect))">Inspect</button>
                            <button class="inspection-button @(_tool == ToolMode.Annotate ? "inspection-button-primary" : "")"
                                    @onclick="@(() => SetToolAsync(ToolMode.Annotate))">Annotate</button>
                        </div>
                        <p class="inspection-page-subtitle" style="margin-top: var(--nickerp-space-2);">
                            @(_tool == ToolMode.Inspect
                                ? "Drag a rectangle to compute ROI stats."
                                : "Drag a rectangle to record an annotation finding.")
                        </p>
                    </div>

                    <div class="inspection-card">
                        <h2 class="inspection-card-title">Window / Level</h2>
                        <label class="viewer-stat">
                            <span class="label">Level (midpoint, 0–255)</span>
                            <input type="range" min="0" max="255" step="1"
                                   @bind="_level" @bind:event="oninput" @bind:after="ReapplyAsync" />
                            <span class="value"><code>@_level</code></span>
                        </label>
                        <label class="viewer-stat">
                            <span class="label">Window (range, 1–255)</span>
                            <input type="range" min="1" max="255" step="1"
                                   @bind="_window" @bind:event="oninput" @bind:after="ReapplyAsync" />
                            <span class="value"><code>@_window</code></span>
                        </label>
                        <button class="inspection-button" @onclick="ResetAsync">Reset</button>
                    </div>

                    <div class="inspection-card">
                        <h2 class="inspection-card-title">Pixel probe</h2>
                        @if (_probe is null)
                        {
                            <p class="inspection-empty">Hover the image to read pixel values.</p>
                        }
                        else
                        {
                            <p class="viewer-stat">
                                <span class="label">@(_probe.X), @(_probe.Y)</span>
                                <span class="value"><code>@_probe.Value</code></span>
                            </p>
                        }
                    </div>

                    @if (_tool == ToolMode.Inspect)
                    {
                        <div class="inspection-card">
                            <h2 class="inspection-card-title">Region of interest</h2>
                            @if (_roi is null)
                            {
                                <p class="inspection-empty">
                                    Drag a rectangle on the image to compute ROI stats. Click without
                                    dragging to clear.
                                </p>
                            }
                            else
                            {
                                <p class="viewer-stat">
                                    <span class="label">size</span>
                                    <span class="value"><code>@(_roi.W)×@(_roi.H) px</code> (n=@_roi.N)</span>
                                </p>
                                <p class="viewer-stat">
                                    <span class="label">mean</span>
                                    <span class="value"><code>@(_roi.Mean.ToString("0.0"))</code></span>
                                </p>
                                <p class="viewer-stat">
                                    <span class="label">min · max</span>
                                    <span class="value"><code>@_roi.Min</code> · <code>@_roi.Max</code></span>
                                </p>
                                <p class="viewer-stat">
                                    <span class="label">stddev</span>
                                    <span class="value"><code>@(_roi.Stddev.ToString("0.0"))</code></span>
                                </p>
                            }
                        </div>
                    }

                    @if (_tool == ToolMode.Annotate)
                    {
                        <div class="inspection-card">
                            <h2 class="inspection-card-title">New annotation</h2>
                            <label class="viewer-stat">
                                <span class="label">Severity</span>
                                <select class="inspection-input" @bind="_pendingSeverity">
                                    <option value="info">info</option>
                                    <option value="warning">warning</option>
                                    <option value="critical">critical</option>
                                </select>
                            </label>
                            <label class="viewer-stat">
                                <span class="label">Note</span>
                                <textarea class="inspection-input" rows="2" @bind="_pendingNote"
                                          placeholder="Optional — what did you see?"></textarea>
                            </label>
                            <p class="inspection-page-subtitle" style="margin-top: var(--nickerp-space-2);">
                                Drag a rectangle on the image to attach this severity + note.
                            </p>
                            @if (!string.IsNullOrEmpty(_annotationMessage))
                            {
                                <p class="inspection-form-message">@_annotationMessage</p>
                            }
                        </div>

                        <div class="inspection-card">
                            <h2 class="inspection-card-title">Recorded annotations (@_annotations.Count)</h2>
                            @if (_annotations.Count == 0)
                            {
                                <p class="inspection-empty">None yet.</p>
                            }
                            else
                            {
                                <table class="inspection-table">
                                    <thead><tr><th>Severity</th><th>Note</th><th>Box</th><th></th></tr></thead>
                                    <tbody>
                                        @foreach (var a in _annotations)
                                        {
                                            <tr>
                                                <td><span class="inspection-pill-state is-@a.Severity.ToLowerInvariant()">@a.Severity</span></td>
                                                <td>@(string.IsNullOrEmpty(a.Note) ? "—" : a.Note)</td>
                                                <td><code>@a.X,@a.Y @a.W×@a.H</code></td>
                                                <td>
                                                    <button class="inspection-button" @onclick="@(() => DeleteAnnotationAsync(a.Id))">Remove</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }

                    <div class="inspection-card">
                        <h2 class="inspection-card-title">Source</h2>
                        <p class="viewer-stat">
                            <span class="label">artifact</span>
                            <span class="value"><code>@_artifact.Id.ToString()[..8]</code></span>
                        </p>
                        <p class="viewer-stat">
                            <span class="label">dimensions</span>
                            <span class="value"><code>@_artifact.WidthPx × @_artifact.HeightPx</code></span>
                        </p>
                        <p class="viewer-stat">
                            <span class="label">preview URL</span>
                            <span class="value"><code>@PreviewUrl</code></span>
                        </p>
                    </div>
                </aside>
            </div>
        }
    </section>
}

@code {
    [Parameter] public Guid CaseId { get; set; }
    [Parameter] public Guid ScanId { get; set; }

    private InspectionCase? _case;
    private Scan? _scan;
    private ScanArtifact? _artifact;
    private string? _scannerName;
    private string? _locationCode;

    private ElementReference _canvasRef;
    private IJSObjectReference? _module;
    private bool _loadFailed;

    private int _level = 128;
    private int _window = 200;

    private ProbeResult? _probe;
    private RoiResult? _roi;

    // Drag state — track in viewport coords; the JS module translates to
    // image pixel space when computing ROI stats.
    private bool _dragging;
    private double _dragStartX;
    private double _dragStartY;

    // -------- Sprint 20 / B1.2 — annotations --------
    private enum ToolMode { Inspect, Annotate }
    private ToolMode _tool = ToolMode.Inspect;
    private string _pendingSeverity = "info";
    private string _pendingNote = string.Empty;
    private string _annotationMessage = string.Empty;
    private List<AnalystAnnotationService.AnnotationView> _annotations = new();

    // -------- Sprint 20 / B1.3 — multi-scan pager --------
    /// <summary>
    /// Ordered list (oldest first) of every scan id under this case.
    /// Drives the prev/next pager + the predictive prefetch.
    /// </summary>
    private List<Guid> _caseScanIds = new();
    private int _scanPosition;       // 1-based for display
    private Guid? _prevScanId;
    private Guid? _nextScanId;

    private string PreviewUrl => _artifact is null ? "" : $"/api/images/{_artifact.Id}/preview";

    protected override async Task OnInitializedAsync()
    {
        _case = await Db.Cases.AsNoTracking().FirstOrDefaultAsync(c => c.Id == CaseId);
        if (_case is null) return;

        _scan = await Db.Scans.AsNoTracking().FirstOrDefaultAsync(s => s.Id == ScanId && s.CaseId == CaseId);
        if (_scan is null) return;

        _artifact = await Db.ScanArtifacts.AsNoTracking()
            .Where(a => a.ScanId == ScanId && a.ArtifactKind == "Primary")
            .OrderBy(a => a.CreatedAt)
            .FirstOrDefaultAsync();

        // Best-effort sidecar context — these are pure display strings, so a
        // missing scanner / location row falls back to "?" rather than aborting.
        var scanner = await Db.ScannerDeviceInstances.AsNoTracking()
            .FirstOrDefaultAsync(s => s.Id == _scan.ScannerDeviceInstanceId);
        _scannerName = scanner?.DisplayName;

        var location = await Db.Locations.AsNoTracking()
            .FirstOrDefaultAsync(l => l.Id == _case.LocationId);
        _locationCode = location?.Code;

        // -------- Sprint 20 / B1.3 — neighbour-scan resolution --------
        // Pull every scan id under this case in capture order; pick the
        // current scan's index to derive prev/next. Cheap query (small
        // cardinality per case) and only one round-trip.
        _caseScanIds = await Db.Scans.AsNoTracking()
            .Where(s => s.CaseId == CaseId)
            .OrderBy(s => s.CapturedAt)
            .Select(s => s.Id)
            .ToListAsync();
        var idx = _caseScanIds.IndexOf(ScanId);
        if (idx >= 0)
        {
            _scanPosition = idx + 1;
            _prevScanId = idx > 0 ? _caseScanIds[idx - 1] : null;
            _nextScanId = idx + 1 < _caseScanIds.Count ? _caseScanIds[idx + 1] : null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (_artifact is null) return;

        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/scan-viewer.js");
            await _module.InvokeAsync<object>("init", _canvasRef, PreviewUrl);

            // -------- Sprint 20 / B1.2 — hydrate persisted annotations --------
            try
            {
                _annotations = await Annotations.ListForArtifactAsync(_artifact.Id);
                if (_annotations.Count > 0)
                {
                    await _module.InvokeVoidAsync("setAnnotations", _canvasRef,
                        _annotations.Select(a => new
                        {
                            id = a.Id, x = a.X, y = a.Y, w = a.W, h = a.H, severity = a.Severity,
                        }).ToArray());
                }
                StateHasChanged();
            }
            catch (Exception ex)
            {
                // Annotation hydration failure is non-fatal — log + carry on
                // so the analyst can still inspect the image.
                Logger.LogWarning(ex,
                    "Annotation hydration failed for artifact {ArtifactId}; carrying on without overlay.",
                    _artifact?.Id);
            }

            // -------- Sprint 20 / B1.3 — predictive prefetch --------
            // Warm the HTTP cache for the next scan's primary artifact
            // preview so the operator's next click feels instant. We
            // resolve the artifact id on the server (single round-trip)
            // and hand its preview URL to the JS prefetch helper.
            if (_nextScanId is { } next)
            {
                var nextArtifactId = await Db.ScanArtifacts.AsNoTracking()
                    .Where(a => a.ScanId == next && a.ArtifactKind == "Primary")
                    .OrderBy(a => a.CreatedAt)
                    .Select(a => (Guid?)a.Id)
                    .FirstOrDefaultAsync();
                if (nextArtifactId is { } nid)
                {
                    try { await _module.InvokeVoidAsync("prefetchPreview", $"/api/images/{nid}/preview"); }
                    catch (JSException) { /* prefetch is best-effort */ }
                }
            }
        }
        catch (JSException ex)
        {
            // Most likely the preview endpoint returned 404 because the
            // pre-render worker hasn't reached this artifact yet. Surface
            // the user-friendly message; log the underlying detail for ops.
            _loadFailed = true;
            Logger.LogInformation(ex,
                "ScanViewer init failed for artifact {ArtifactId} — likely preview not yet rendered.",
                _artifact?.Id);
            StateHasChanged();
        }
    }

    private async Task ReapplyAsync()
    {
        if (_module is null) return;
        try { await _module.InvokeVoidAsync("applyWindowLevel", _canvasRef, _window, _level); }
        catch (JSException) { /* viewer not initialised — ignore */ }
    }

    private async Task ResetAsync()
    {
        _level = 128;
        _window = 200;
        await ReapplyAsync();
    }

    private async Task SetToolAsync(ToolMode tool)
    {
        _tool = tool;
        _annotationMessage = string.Empty;
        if (_module is null) return;
        try
        {
            await _module.InvokeVoidAsync("setTool", _canvasRef,
                tool == ToolMode.Annotate ? "annotate" : "inspect");
        }
        catch (JSException) { /* viewer not initialised — ignore */ }
    }

    private async Task OnMouseMove(MouseEventArgs e)
    {
        if (_module is null) return;
        try
        {
            var probe = await _module.InvokeAsync<ProbeResult?>("getPixelAt", _canvasRef, e.ClientX, e.ClientY);
            if (probe is not null)
            {
                _probe = probe;
                StateHasChanged();
            }
        }
        catch (JSException) { /* ignore — module not yet ready */ }
    }

    private void OnMouseDown(MouseEventArgs e)
    {
        if (_module is null) return;
        _dragging = true;
        _dragStartX = e.ClientX;
        _dragStartY = e.ClientY;
    }

    private async Task OnMouseUp(MouseEventArgs e)
    {
        if (_module is null || !_dragging) return;
        _dragging = false;

        if (_tool == ToolMode.Annotate)
        {
            await FinalizeAnnotationAsync(e);
            return;
        }

        try
        {
            // setRoi returns null for a sub-2px "click" — the JS side also
            // calls clearRoi internally in that case, so we just mirror.
            var roi = await _module.InvokeAsync<RoiResult?>(
                "setRoi", _canvasRef, _dragStartX, _dragStartY, e.ClientX, e.ClientY);
            _roi = roi;
            StateHasChanged();
        }
        catch (JSException) { /* ignore */ }
    }

    private async Task FinalizeAnnotationAsync(MouseEventArgs e)
    {
        if (_module is null || _artifact is null) return;
        try
        {
            var rect = await _module.InvokeAsync<RectInImageSpace?>(
                "finalizeAnnotation", _canvasRef, _dragStartX, _dragStartY, e.ClientX, e.ClientY);
            if (rect is null)
            {
                _annotationMessage = "Drag a larger rectangle (≥ 2 image px) to record an annotation.";
                StateHasChanged();
                return;
            }

            var saved = await Annotations.AddAnnotationAsync(
                CaseId, _artifact.Id,
                rect.X, rect.Y, rect.W, rect.H,
                _pendingSeverity, _pendingNote);

            _annotations.Insert(0, new AnalystAnnotationService.AnnotationView(
                saved.Id, _artifact.Id, rect.X, rect.Y, rect.W, rect.H,
                saved.Severity, saved.Note, saved.CreatedAt));

            await _module.InvokeVoidAsync("setAnnotations", _canvasRef,
                _annotations.Select(a => new
                {
                    id = a.Id, x = a.X, y = a.Y, w = a.W, h = a.H, severity = a.Severity,
                }).ToArray());

            _annotationMessage = $"Annotation saved (severity={saved.Severity}).";
            _pendingNote = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _annotationMessage = UserFacingError.Render(Logger, ex,
                "INSP-VIEWER-ANNOTATION-SAVE-FAILED",
                "Failed to record annotation.");
            StateHasChanged();
        }
    }

    private async Task DeleteAnnotationAsync(Guid findingId)
    {
        if (_module is null || _artifact is null) return;
        try
        {
            var ok = await Annotations.DeleteAnnotationAsync(findingId);
            if (!ok)
            {
                _annotationMessage = "Couldn't delete the annotation — only the analyst who created it can remove it.";
                StateHasChanged();
                return;
            }

            _annotations.RemoveAll(a => a.Id == findingId);
            await _module.InvokeVoidAsync("setAnnotations", _canvasRef,
                _annotations.Select(a => new
                {
                    id = a.Id, x = a.X, y = a.Y, w = a.W, h = a.H, severity = a.Severity,
                }).ToArray());
            _annotationMessage = "Annotation removed.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _annotationMessage = UserFacingError.Render(Logger, ex,
                "INSP-VIEWER-ANNOTATION-DELETE-FAILED",
                "Failed to remove annotation.");
            StateHasChanged();
        }
    }

    private void OnMouseLeave(MouseEventArgs _)
    {
        // Drop the probe display when the cursor leaves the canvas;
        // a stale "(x, y) = value" looks like the probe is frozen.
        _probe = null;
        // Don't cancel an in-flight drag — the user might still complete
        // it on the document; mouseup will fire wherever it lands.
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _canvasRef);
                await _module.DisposeAsync();
            }
            catch (JSException) { /* circuit already torn down */ }
            catch (JSDisconnectedException) { /* circuit already torn down */ }
        }
    }

    private sealed record ProbeResult(int X, int Y, int Value);
    private sealed record RoiResult(int X, int Y, int W, int H, double Mean, int Min, int Max, double Stddev, int N);
    private sealed record RectInImageSpace(int X, int Y, int W, int H);
}
