@page "/admin/reports/errors"
@* Sprint 33 / B7.1 — error events drill-down page.

   Paged list of audit events whose EventType contains ".error" with
   filters for event type, entity type, and date range. Clicking a row
   that targets an InspectionCase navigates to /cases/{id}; other
   entity types just expand the payload. *@
@attribute [Authorize(Roles = "Inspection.Admin")]
@using Microsoft.AspNetCore.Components
@using NickERP.Inspection.Web.Components.Shared
@using NickERP.Inspection.Web.Services
@using NickERP.Platform.Tenancy
@inject ReportsService Reports
@inject ITenantContext Tenant
@inject NavigationManager Nav

<PageTitle>Errors — Reports — Inspection v2</PageTitle>

<header class="inspection-page-header">
    <div>
        <h1>Error investigation</h1>
        <p class="inspection-page-subtitle">
            Audit events tagged as <code>*.error</code>. Filter by type and date; click a row pointing at an inspection case to jump to its detail. <a href="/admin/reports">Back to dashboard</a>.
        </p>
    </div>
</header>

@if (!Tenant.IsResolved)
{
    <p class="inspection-empty">Tenant context is not resolved.</p>
}
else
{
    <section class="inspection-section">
        <div class="inspection-card">
            <h2 class="inspection-card-title">Filters</h2>
            <div class="inspection-filter-bar">
                <label>
                    Event type contains
                    <input type="text" @bind="_eventTypeFilter" @bind:after="ReloadAsync" />
                </label>
                <label>
                    Entity type contains
                    <input type="text" @bind="_entityTypeFilter" @bind:after="ReloadAsync" />
                </label>
                <label>
                    From (UTC)
                    <input type="datetime-local" @bind="_from" @bind:after="ReloadAsync" />
                </label>
                <label>
                    To (UTC)
                    <input type="datetime-local" @bind="_to" @bind:after="ReloadAsync" />
                </label>
                <button class="inspection-button" type="button" @onclick="ResetFiltersAsync">Reset</button>
            </div>
        </div>
    </section>

    <section class="inspection-section">
        <div class="inspection-card">
            <header class="inspection-button-row">
                <h2 class="inspection-card-title">Error events</h2>
                <span class="inspection-page-subtitle">@_total total — page @_page</span>
            </header>

            @if (_loadError is not null)
            {
                <p class="inspection-empty">Failed to load: @_loadError</p>
            }
            else if (_rows is null)
            {
                <p>Loading…</p>
            }
            else if (_rows.Count == 0)
            {
                <p class="inspection-empty">No error events match the current filters.</p>
            }
            else
            {
                <table class="inspection-table">
                    <thead>
                        <tr>
                            <th>When (UTC)</th>
                            <th>Event type</th>
                            <th>Entity</th>
                            <th>Actor</th>
                            <th>Correlation</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _rows)
                        {
                            <tr class="@(_expandedId == r.EventId ? "inspection-row-expanded" : "")">
                                <td>@r.OccurredAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td><code>@r.EventType</code></td>
                                <td>
                                    <code>@r.EntityType</code>
                                    <br />
                                    <span class="inspection-page-subtitle">@r.EntityId</span>
                                </td>
                                <td>@(r.ActorUserId?.ToString() ?? "—")</td>
                                <td><code>@(r.CorrelationId ?? "—")</code></td>
                                <td>
                                    <button class="inspection-button" type="button" @onclick="() => ToggleExpand(r.EventId)">
                                        @(_expandedId == r.EventId ? "Hide" : "Inspect") payload
                                    </button>
                                    @if (string.Equals(r.EntityType, "InspectionCase", StringComparison.OrdinalIgnoreCase) && Guid.TryParse(r.EntityId, out var caseId))
                                    {
                                        <a class="inspection-button" href="@($"/cases/{caseId}")">Open case</a>
                                    }
                                </td>
                            </tr>
                            @if (_expandedId == r.EventId)
                            {
                                <tr class="inspection-row-detail">
                                    <td colspan="6">
                                        <JsonPayloadViewer Title="Payload" Json="@r.PayloadJson" />
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

                <div class="inspection-button-row">
                    <button class="inspection-button" type="button"
                            disabled="@(_page <= 1)"
                            @onclick="PreviousPageAsync">‹ Previous</button>
                    <span class="inspection-page-subtitle">Page @_page</span>
                    <button class="inspection-button" type="button"
                            disabled="@(_rows.Count < _pageSize)"
                            @onclick="NextPageAsync">Next ›</button>
                </div>
            }
        </div>
    </section>
}

@code {
    private const int _pageSize = 25;
    private int _page = 1;
    private int _total;
    private string? _eventTypeFilter;
    private string? _entityTypeFilter;
    private DateTime? _from;
    private DateTime? _to;
    private IReadOnlyList<ErrorEventRow>? _rows;
    private Guid? _expandedId;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loadError = null;
        try
        {
            if (!Tenant.IsResolved) return;
            DateTimeOffset? from = _from.HasValue ? new DateTimeOffset(_from.Value, TimeSpan.Zero) : null;
            DateTimeOffset? to = _to.HasValue ? new DateTimeOffset(_to.Value, TimeSpan.Zero) : null;
            var paged = await Reports.ListErrorEventsAsync(
                _eventTypeFilter, _entityTypeFilter, from, to, _page, _pageSize);
            _total = paged.Total;
            _rows = paged.Rows;
        }
        catch (Exception ex)
        {
            _loadError = $"{ex.GetType().Name}: {ex.Message}";
        }
    }

    private async Task ResetFiltersAsync()
    {
        _eventTypeFilter = null;
        _entityTypeFilter = null;
        _from = null;
        _to = null;
        _page = 1;
        _expandedId = null;
        await ReloadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_page <= 1) return;
        _page--;
        _expandedId = null;
        await ReloadAsync();
    }

    private async Task NextPageAsync()
    {
        _page++;
        _expandedId = null;
        await ReloadAsync();
    }

    private void ToggleExpand(Guid id)
    {
        _expandedId = _expandedId == id ? null : id;
    }
}
