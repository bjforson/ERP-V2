@page "/cases/{CaseId:guid}"
@attribute [Authorize]
@using System.Text.Json
@using Microsoft.AspNetCore.Diagnostics
@using Microsoft.AspNetCore.Http
@using Microsoft.EntityFrameworkCore
@using NickERP.Inspection.Application.AnalysisServices
@using NickERP.Inspection.Authorities.Abstractions
@using NickERP.Inspection.Core.Entities
@using NickERP.Inspection.Database
@using NickERP.Inspection.Web.Services
@inject InspectionDbContext Db
@inject CaseWorkflowService Workflow
@inject CaseClaimService Claims
@inject AuthenticationStateProvider AuthState
@inject ILogger<CaseDetail> Logger

<PageTitle>Case @ShortId — Inspection v2</PageTitle>

@if (_notFound)
{
    @* FU-2 — when the case load returns null (either because no row exists
       at this id at all, or because RLS hid a foreign-tenant row), we set
       Response.StatusCode = 404 in OnInitializedAsync (see @code below).

       Why this shape (status-code on cascading HttpContext + inline body)
       over a NavigateTo("/not-found") redirect: keeps the browser at
       /cases/{guid} (so back-button + URL-share semantics line up with
       what the user did), avoids a redirect roundtrip, and avoids
       provoking a fresh DI scope via UseStatusCodePagesWithReExecute
       (which races EF DbContext disposal on the test host). Mirrors the
       pattern in Error.razor.

       We render the not-found body INLINE here instead of relying on
       UseStatusCodePagesWithReExecute to swap in NotFound.razor — the
       re-execute creates a new scope whose Inspection / Identity
       DbContexts open fresh Postgres connections through the F1 tenant
       interceptor, and on a small body the response disposes before the
       new scope's connection-open completes (Npgsql 'Connecting' state
       race). OnInitializedAsync also flips IStatusCodePagesFeature.Enabled
       off for this request so the middleware doesn't try the re-execute
       at all. Body text is deliberately generic — never the
       SubjectIdentifier — so we don't disclose tenant existence. *@
    <header class="inspection-page-header">
        <div>
            <h1>Case not found</h1>
            <p class="inspection-page-subtitle">
                The case you requested does not exist or you do not have access to it.
            </p>
        </div>
    </header>

    <section class="inspection-section">
        <p class="inspection-empty">
            Try the <a href="/cases">Cases</a> list.
        </p>
    </section>
}
else if (_case is null)
{
    <p>Loading…</p>
}
else
{
    <header class="inspection-page-header">
        <div>
            <h1>Case <code>@_case.SubjectIdentifier</code> &nbsp;
                <span class="inspection-pill-state is-@_case.State.ToString().ToLowerInvariant()">@_case.State</span>
            </h1>
            <p class="inspection-page-subtitle">
                @_case.SubjectType at @(_locationsById.GetValueOrDefault(_case.LocationId)?.Name ?? "?") •
                opened @_case.OpenedAt.ToString("yyyy-MM-dd HH:mm") •
                in this state since @_case.StateEnteredAt.ToString("yyyy-MM-dd HH:mm")
            </p>
            @* Sprint 14 / VP6 Phase C — active-claim badge. Shown when
               the case is locked under shared visibility and the
               current viewer isn't the claimer. The acquire happens
               server-side on AssignSelf (CaseWorkflowService); this
               panel is read-only. *@
            @if (_activeClaim is not null)
            {
                var ageMin = (int)Math.Max(0, (DateTimeOffset.UtcNow - _activeClaim.ClaimedAt).TotalMinutes);
                var serviceName = _activeClaim.AnalysisService?.Name ?? "(unknown service)";
                var owner = _activeClaim.ClaimedByUserId.ToString()[..8];
                var owned = _activeClaim.ClaimedByUserId == _userId;
                <p class="inspection-claim-badge @(owned ? "is-mine" : "is-claimed-by-other")">
                    @if (owned)
                    {
                        <span>You hold this claim under <strong>@serviceName</strong> since @ageMin minute(s) ago.</span>
                        <button type="button" class="inspection-button" @onclick="ReleaseClaimAsync">Release claim</button>
                    }
                    else
                    {
                        <span>Claimed by <code>@owner</code> in <strong>@serviceName</strong> · @ageMin minute(s) ago. Read-only for you.</span>
                    }
                </p>
            }
        </div>
    </header>

    <section class="inspection-section">
        <div class="inspection-card">
            <h2 class="inspection-card-title">Workflow actions</h2>

            <div class="inspection-button-row">
                <select class="inspection-input" @bind="_selectedScannerId">
                    <option value="">— pick scanner —</option>
                    @foreach (var s in _scanners)
                    {
                        <option value="@s.Id">@s.TypeCode — @s.DisplayName</option>
                    }
                </select>
                <button class="inspection-button" @onclick="SimulateScan" disabled="@(_selectedScannerId == Guid.Empty)">Simulate scan</button>

                <select class="inspection-input" @bind="_selectedExternalId">
                    <option value="">— pick external system —</option>
                    @foreach (var e in _externals)
                    {
                        <option value="@e.Id">@e.TypeCode — @e.DisplayName</option>
                    }
                </select>
                <button class="inspection-button" @onclick="FetchDocuments" disabled="@(_selectedExternalId == Guid.Empty)">Fetch documents</button>

                <button class="inspection-button" @onclick="AssignSelf" disabled="@(_case.State == InspectionWorkflowState.Submitted || _case.State == InspectionWorkflowState.Closed)">Assign me + start review</button>

                <button class="inspection-button" @onclick="EvaluateRules" disabled="@(_documents.Count == 0)">Run authority checks</button>
            </div>

            <div class="inspection-form-row" style="margin-top: var(--nickerp-space-3);">
                <label>
                    <span>Verdict</span>
                    <InputSelect class="inspection-input" @bind-Value="_verdictDecision">
                        @foreach (var d in Enum.GetValues<VerdictDecision>())
                        {
                            <option value="@d">@d</option>
                        }
                    </InputSelect>
                </label>
                <label>
                    <span>Confidence (0.0–1.0)</span>
                    <InputNumber class="inspection-input" step="0.05" @bind-Value="_confidence" />
                </label>
                <label style="grid-column: 1 / -1;">
                    <span>Basis</span>
                    <InputTextArea class="inspection-input" rows="2" @bind-Value="_basis" placeholder="One or two sentences justifying the call." />
                </label>
            </div>
            <div class="inspection-button-row" style="margin-top: var(--nickerp-space-2);">
                <button class="inspection-button inspection-button-primary" @onclick="SetVerdict">Set verdict</button>

                <select class="inspection-input" @bind="_submitToId">
                    <option value="">— submit to —</option>
                    @foreach (var e in _externals)
                    {
                        <option value="@e.Id">@e.TypeCode — @e.DisplayName</option>
                    }
                </select>
                <button class="inspection-button" @onclick="Submit" disabled="@(_submitToId == Guid.Empty || _case.Verdict is null)">Submit verdict</button>

                <button class="inspection-button" @onclick="Close" disabled="@(_case.State == InspectionWorkflowState.Closed)">Close case</button>
            </div>

            @if (!string.IsNullOrEmpty(_message))
            {
                <p class="inspection-form-message" style="margin-top: var(--nickerp-space-3);">@_message</p>
            }
        </div>
    </section>

    <div class="inspection-detail-grid">
        <div>
            <section class="inspection-section">
                <h2>Scans (@_scans.Count)</h2>
                @if (_scans.Count == 0) { <p class="inspection-empty">No scans yet.</p> }
                else
                {
                    <table class="inspection-table">
                        <thead><tr><th></th><th>Captured</th><th>Mode</th><th>Artifacts</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var s in _scans)
                            {
                                <tr>
                                    <td>
                                        @if (_primaryArtifactByScan.TryGetValue(s.Id, out var artId))
                                        {
                                            <img class="inspection-thumb"
                                                 src="/api/images/@artId/thumbnail"
                                                 alt="Scan thumbnail"
                                                 loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="inspection-thumb is-empty" aria-hidden="true"></div>
                                        }
                                    </td>
                                    <td>@s.CapturedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@s.Mode</td>
                                    <td>@_artifactsPerScan.GetValueOrDefault(s.Id, 0)</td>
                                    <td>
                                        @* V4 — analyst W/L viewer link. Stays inert when there's no
                                           primary artifact yet; the viewer page itself shows the
                                           "no preview" fallback if the user navigates anyway. *@
                                        <a href="/cases/@CaseId/scans/@s.Id" class="inspection-button">Open viewer</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>

            <section class="inspection-section">
                <h2>Authority documents (@_documents.Count)</h2>
                @if (_documents.Count == 0) { <p class="inspection-empty">No documents fetched yet.</p> }
                else
                {
                    <table class="inspection-table">
                        <thead><tr><th>Type</th><th>Reference</th><th>Received</th></tr></thead>
                        <tbody>
                            @foreach (var d in _documents)
                            {
                                <tr><td>@d.DocumentType</td><td><code>@d.ReferenceNumber</code></td><td>@d.ReceivedAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
                            }
                        </tbody>
                    </table>
                }
            </section>

            @if (_rulesResult is not null)
            {
                <section class="inspection-section">
                    <h2>Authority checks</h2>
                    <div class="inspection-card">
                        @if (_rulesResult.Violations.Count == 0 && _rulesResult.Mutations.Count == 0 && _rulesResult.ProviderErrors.Count == 0)
                        {
                            <p class="inspection-empty">No violations. No suggested mutations. Case is clean.</p>
                        }
                        else
                        {
                            @if (_rulesResult.Violations.Count > 0)
                            {
                                <h3>Violations (@_rulesResult.Violations.Count)</h3>
                                <table class="inspection-table">
                                    <thead><tr><th>Authority</th><th>Rule</th><th>Severity</th><th>Message</th></tr></thead>
                                    <tbody>
                                        @foreach (var ev in _rulesResult.Violations)
                                        {
                                            <tr>
                                                <td><code>@ev.AuthorityCode</code></td>
                                                <td><code>@ev.Violation.RuleCode</code></td>
                                                <td><span class="inspection-pill-state is-@ev.Violation.Severity.ToLowerInvariant()">@ev.Violation.Severity</span></td>
                                                <td>@ev.Violation.Message</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            @if (_rulesResult.Mutations.Count > 0)
                            {
                                <h3 style="margin-top: var(--nickerp-space-3);">Suggested mutations (@_rulesResult.Mutations.Count)</h3>
                                <ul>
                                    @foreach (var em in _rulesResult.Mutations)
                                    {
                                        <li><code>@em.AuthorityCode</code> · <code>@em.Mutation.MutationKind</code> — @em.Mutation.Reason</li>
                                    }
                                </ul>
                            }
                            @if (_rulesResult.ProviderErrors.Count > 0)
                            {
                                <h3 style="margin-top: var(--nickerp-space-3);">Provider errors (@_rulesResult.ProviderErrors.Count)</h3>
                                <ul>
                                    @foreach (var err in _rulesResult.ProviderErrors)
                                    {
                                        <li><code>@err</code></li>
                                    }
                                </ul>
                            }
                        }
                    </div>
                </section>
            }

            <section class="inspection-section">
                <h2>Submissions (@_submissions.Count)</h2>
                @if (_submissions.Count == 0) { <p class="inspection-empty">No verdict submissions yet.</p> }
                else
                {
                    <table class="inspection-table">
                        <thead><tr><th>External system</th><th>Status</th><th>Submitted</th></tr></thead>
                        <tbody>
                            @foreach (var s in _submissions)
                            {
                                <tr><td>@(_externals.FirstOrDefault(e => e.Id == s.ExternalSystemInstanceId)?.DisplayName ?? "?")</td>
                                    <td>@s.Status</td>
                                    <td>@s.SubmittedAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
        </div>

        <aside>
            <section class="inspection-section">
                <h2>Verdict</h2>
                <div class="inspection-card">
                    @if (_case.Verdict is null)
                    {
                        <p class="inspection-empty">No verdict yet.</p>
                    }
                    else
                    {
                        <p><strong>@_case.Verdict.Decision</strong> by analyst <code>@_case.Verdict.DecidedByUserId.ToString()[..8]</code> at @_case.Verdict.DecidedAt.ToString("yyyy-MM-dd HH:mm")</p>
                        <p>@_case.Verdict.Basis</p>
                    }
                </div>
            </section>
        </aside>
    </div>
}

@code {
    [Parameter] public Guid CaseId { get; set; }

    // FU-2 — cascading HttpContext lets us set Response.StatusCode = 404
    // on the foreign-tenant / not-found path. Null in interactive
    // (websocket) renders, which is fine: the not-found path only runs
    // on the initial SSR load (before _case is bound), and after that
    // any re-Reload() that returns null only happens for an existing
    // case that was just deleted in another tab — vanishingly rare and
    // not worth the round-trip.
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private InspectionCase? _case;
    private bool _notFound;
    /// <summary>VP6 Phase C — active claim (or null if none); read-only banner.</summary>
    private CaseClaim? _activeClaim;
    /// <summary>VP6 Phase C — viewer's identity user id, used to compare against the claim owner.</summary>
    private Guid _userId;
    private bool _isAdmin;
    private List<Scan> _scans = new();
    private List<AuthorityDocument> _documents = new();
    private List<OutboundSubmission> _submissions = new();
    private Dictionary<Guid, int> _artifactsPerScan = new();
    /// <summary>ScanId → first Primary ScanArtifact.Id, used for per-scan thumbnails.</summary>
    private Dictionary<Guid, Guid> _primaryArtifactByScan = new();
    private List<ScannerDeviceInstance> _scanners = new();
    private List<ExternalSystemInstance> _externals = new();
    private Dictionary<Guid, Location> _locationsById = new();

    private Guid _selectedScannerId;
    private Guid _selectedExternalId;
    private Guid _submitToId;
    private VerdictDecision _verdictDecision = VerdictDecision.Clear;
    private double _confidence = 0.85;
    private string _basis = string.Empty;
    private string _message = string.Empty;
    private RulesEvaluationResult? _rulesResult;

    private string ShortId => _case is null ? "" : _case.Id.ToString()[..8];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var idClaim = state.User?.FindFirst("nickerp:id")?.Value;
        Guid.TryParse(idClaim, out _userId);
        _isAdmin = state.User?.IsInRole("platform.admin") == true
                   || state.User?.IsInRole("Identity.Admin") == true
                   || state.User?.HasClaim("nickerp:scope", "Identity.Admin") == true
                   || state.User?.HasClaim("nickerp:scope", "platform.admin") == true;
        await Reload();
    }

    private async Task Reload()
    {
        _case = await Db.Cases.Include(c => c.Verdict).FirstOrDefaultAsync(c => c.Id == CaseId);
        if (_case is null)
        {
            // FU-2 — Either the case id doesn't exist, or it belongs to a
            // different tenant and the TenantConnectionInterceptor's
            // app.tenant_id push caused RLS to hide the row from this
            // connection. Both cases look identical from here (and that's
            // the right posture: don't disclose tenant existence). Set 404
            // on the response; the @if (_notFound) branch above renders an
            // inline not-found body (so the URL stays at /cases/{guid} and
            // there's no redirect roundtrip). The HttpContext null-check
            // guards against the post-prerender interactive path where
            // there is no longer an ambient response to mutate.
            //
            // We also turn OFF the Program.cs-wired
            // UseStatusCodePagesWithReExecute("/not-found") for this
            // request: re-executing into NotFound.razor under a fresh DI
            // scope opens new Postgres connections through the F1 tenant
            // interceptor that race EF DbContext disposal at scope-end on
            // the test host, surfacing as "Can't close, connection is in
            // state Connecting". Disabling the feature means the inline
            // body above is the response body — same status code, same
            // visual outcome, no re-execute scope churn.
            _notFound = true;
            if (HttpContext is { Response.HasStarted: false } http)
            {
                http.Response.StatusCode = StatusCodes.Status404NotFound;
                var scpFeature = http.Features.Get<IStatusCodePagesFeature>();
                if (scpFeature is not null) scpFeature.Enabled = false;
            }
            return;
        }
        _scans = await Db.Scans.AsNoTracking().Where(s => s.CaseId == CaseId).OrderByDescending(s => s.CapturedAt).ToListAsync();
        _documents = await Db.AuthorityDocuments.AsNoTracking().Where(d => d.CaseId == CaseId).OrderByDescending(d => d.ReceivedAt).ToListAsync();
        _submissions = await Db.OutboundSubmissions.AsNoTracking().Where(s => s.CaseId == CaseId).OrderByDescending(s => s.SubmittedAt).ToListAsync();
        var scanIds = _scans.Select(s => s.Id).ToList();
        _artifactsPerScan = await Db.ScanArtifacts.AsNoTracking()
            .Where(a => scanIds.Contains(a.ScanId))
            .GroupBy(a => a.ScanId)
            .Select(g => new { g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.Key, x => x.Count);
        _primaryArtifactByScan = await Db.ScanArtifacts.AsNoTracking()
            .Where(a => scanIds.Contains(a.ScanId) && a.ArtifactKind == "Primary")
            .GroupBy(a => a.ScanId)
            .Select(g => new { ScanId = g.Key, ArtifactId = g.First().Id })
            .ToDictionaryAsync(x => x.ScanId, x => x.ArtifactId);

        _scanners = await Db.ScannerDeviceInstances.AsNoTracking()
            .Where(s => s.LocationId == _case.LocationId && s.IsActive)
            .OrderBy(s => s.DisplayName).ToListAsync();
        _externals = await Db.ExternalSystemInstances.AsNoTracking()
            .Where(x => x.IsActive)
            .OrderBy(x => x.DisplayName).ToListAsync();
        _locationsById = await Db.Locations.AsNoTracking().ToDictionaryAsync(l => l.Id);

        // Sprint A1 — hydrate the rules pane from the persisted snapshot
        // table so the analyst doesn't have to click "Run authority checks"
        // again on every reload. One row per (case, AuthorityCode); we
        // collect the latest set across all authorities into a single
        // RulesEvaluationResult mirroring what EvaluateAuthorityRulesAsync
        // would have returned. Fetch path / button click overwrite this
        // with their fresh result; absent any persisted snapshot, the pane
        // stays hidden as before.
        _rulesResult = await HydrateRulesResultAsync();

        // Sprint 14 / VP6 Phase C — load active claim metadata so the
        // header banner can show "claimed by [user] in [service]" or
        // "you hold this claim" + a Release button. Single round-trip
        // through CaseClaimService so the unique-partial-index narrowing
        // matches the rest of the claim flow.
        _activeClaim = await Claims.GetActiveClaimAsync(CaseId);
    }

    private async Task ReleaseClaimAsync()
    {
        if (_activeClaim is null) return;
        try
        {
            await Claims.ReleaseClaimAsync(_activeClaim.Id, _userId, _isAdmin);
            _message = "Claim released.";
            await Reload();
        }
        catch (Exception ex)
        {
            _message = $"Release claim failed: {ex.Message}";
        }
    }

    /// <summary>
    /// Reconstitute the latest <see cref="RulesEvaluationResult"/> for the
    /// current case by reading the per-authority snapshots persisted by
    /// <c>CaseWorkflowService.EvaluateAuthorityRulesAsync</c>. Returns
    /// <c>null</c> when no rules have ever been evaluated for the case
    /// (so the rules pane stays hidden — same as before A1 landed).
    /// </summary>
    private async Task<RulesEvaluationResult?> HydrateRulesResultAsync()
    {
        var rows = await Db.RuleEvaluations.AsNoTracking()
            .Where(r => r.CaseId == CaseId)
            .OrderByDescending(r => r.EvaluatedAt)
            .ToListAsync();
        if (rows.Count == 0) return null;

        var violations = new List<EvaluatedViolation>();
        var mutations = new List<EvaluatedMutation>();
        var errors = new List<string>();
        foreach (var row in rows)
        {
            try
            {
                var vs = JsonSerializer.Deserialize<List<EvaluatedViolation>>(row.ViolationsJson);
                if (vs is not null) violations.AddRange(vs);
                var ms = JsonSerializer.Deserialize<List<EvaluatedMutation>>(row.MutationsJson);
                if (ms is not null) mutations.AddRange(ms);
                var es = JsonSerializer.Deserialize<List<string>>(row.ProviderErrorsJson);
                if (es is not null) errors.AddRange(es);
            }
            catch (JsonException ex)
            {
                // A malformed snapshot row shouldn't take the page down —
                // log + skip; the analyst can re-run rules to repair it.
                Logger.LogWarning(ex,
                    "Failed to deserialize RuleEvaluation {RowId} for case {CaseId}; skipping.",
                    row.Id, CaseId);
            }
        }
        return new RulesEvaluationResult(violations, mutations, errors);
    }

    private async Task SimulateScan()
    {
        try { await Workflow.SimulateScanAsync(CaseId, _selectedScannerId); _message = "Scan recorded."; await Reload(); }
        catch (Exception ex) { _message = UserFacingError.Render(Logger, ex, "INSP-CASE-SIMULATE-SCAN-FAILED", "Failed to record scan."); }
    }

    private async Task FetchDocuments()
    {
        try
        {
            // D3: FetchDocumentsAsync now also auto-fires the authority-rules
            // pack server-side and hands the result back in the same call.
            // Surface it directly so the rules pane shows up without a second
            // click; if Rules is null the auto-eval threw (already logged) and
            // the analyst can fall back to the "Run authority checks" button.
            var result = await Workflow.FetchDocumentsAsync(CaseId, _selectedExternalId);
            _rulesResult = result.Rules;
            if (result.Rules is { } r)
            {
                _message = $"Fetched {result.Documents.Count} document(s). {r.Violations.Count} violation(s), {r.Mutations.Count} suggested mutation(s).";
            }
            else
            {
                _message = $"Fetched {result.Documents.Count} document(s). Auto rule check failed — use 'Run authority checks' to retry.";
            }
            await Reload();
        }
        catch (Exception ex)
        {
            // F5: route through UserFacingError so ex.Message (which can include
            // EF/Npgsql connection details, table names, or PII like container
            // numbers) doesn't leak into the analyst UI.
            _message = UserFacingError.Render(Logger, ex, "INSP-CASE-FETCH-DOCS-FAILED", "Failed to fetch documents.");
        }
    }

    private async Task AssignSelf()
    {
        try { await Workflow.AssignSelfAndStartReviewAsync(CaseId); _message = "Assigned to you. Review session started."; await Reload(); }
        catch (Exception ex) { _message = UserFacingError.Render(Logger, ex, "INSP-CASE-ASSIGN-SELF-FAILED", "Failed to assign case to you."); }
    }

    private async Task SetVerdict()
    {
        try { await Workflow.SetVerdictAsync(CaseId, _verdictDecision, _basis, _confidence); _message = "Verdict recorded."; await Reload(); }
        catch (Exception ex) { _message = UserFacingError.Render(Logger, ex, "INSP-CASE-SET-VERDICT-FAILED", "Failed to record verdict."); }
    }

    private async Task Submit()
    {
        try { var sub = await Workflow.SubmitAsync(CaseId, _submitToId); _message = $"Submission status: {sub.Status}."; await Reload(); }
        catch (Exception ex) { _message = UserFacingError.Render(Logger, ex, "INSP-CASE-SUBMIT-FAILED", "Failed to submit case."); }
    }

    private async Task Close()
    {
        try { await Workflow.CloseCaseAsync(CaseId); _message = "Case closed."; await Reload(); }
        catch (Exception ex) { _message = UserFacingError.Render(Logger, ex, "INSP-CASE-CLOSE-FAILED", "Failed to close case."); }
    }

    private async Task EvaluateRules()
    {
        try
        {
            _rulesResult = await Workflow.EvaluateAuthorityRulesAsync(CaseId);
            var v = _rulesResult.Violations.Count;
            var m = _rulesResult.Mutations.Count;
            _message = $"Evaluated. {v} violation(s), {m} suggested mutation(s).";
        }
        catch (Exception ex) { _message = UserFacingError.Render(Logger, ex, "INSP-CASE-EVALUATE-RULES-FAILED", "Failed to evaluate authority rules."); }
    }
}
