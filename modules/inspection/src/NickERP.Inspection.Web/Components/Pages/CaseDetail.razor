    private RenderFragment RulesPane => __builder =>
    {
        <h2>Rules + findings</h2>
        <div class="inspection-card">
            <h3 class="inspection-card-title">Authority checks</h3>
            @if (_rulesResult is null)
            {
                <p class="inspection-empty">No authority-rules evaluation yet — use the Overview tab.</p>
            }
            else if (_rulesResult.Violations.Count == 0
                     && _rulesResult.Mutations.Count == 0
                     && _rulesResult.ProviderErrors.Count == 0)
            {
                <p class="inspection-empty">No violations. No suggested mutations. Case is clean.</p>
            }
            else
            {
                @if (_rulesResult.Violations.Count > 0)
                {
                    <h4>Violations (@_rulesResult.Violations.Count)</h4>
                    <table class="inspection-table">
                        <thead><tr><th>Authority</th><th>Rule</th><th>Severity</th><th>Message</th></tr></thead>
                        <tbody>
                            @foreach (var ev in _rulesResult.Violations)
                            {
                                <tr>
                                    <td><code>@ev.AuthorityCode</code></td>
                                    <td><code>@ev.Violation.RuleCode</code></td>
                                    <td><span class="inspection-pill-state is-@ev.Violation.Severity.ToLowerInvariant()">@ev.Violation.Severity</span></td>
                                    <td>@ev.Violation.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                @if (_rulesResult.Mutations.Count > 0)
                {
                    <h4 style="margin-top: var(--nickerp-space-3);">Suggested mutations (@_rulesResult.Mutations.Count)</h4>
                    <ul>
                        @foreach (var em in _rulesResult.Mutations)
                        {
                            <li><code>@em.AuthorityCode</code> · <code>@em.Mutation.MutationKind</code> — @em.Mutation.Reason</li>
                        }
                    </ul>
                }
                @if (_rulesResult.ProviderErrors.Count > 0)
                {
                    <h4 style="margin-top: var(--nickerp-space-3);">Provider errors (@_rulesResult.ProviderErrors.Count)</h4>
                    <ul>
                        @foreach (var err in _rulesResult.ProviderErrors)
                        {
                            <li><code>@err</code></li>
                        }
                    </ul>
                }
            }
        </div>

        @*
            Sprint 32 FU-C — split the original "findings" pane into two:
            one for system-authored Findings (validation rules + future
            Sprint 31 completeness signals) and one for analyst
            observations (annotations etc.). Same physical tab; clearer
            mental model. Each row in the validation pane links to the
            Sprint 28 rules-admin drill-down at /admin/rules/{ruleId}.
        *@
        <div class="inspection-card" data-testid="validation-findings-pane">
            <h3 class="inspection-card-title">Validation rules (@_validationFindings.Count)</h3>
            @if (!_findingsLoaded) { <p>Loading…</p> }
            else if (_validationFindings.Count == 0)
            {
                <p class="inspection-empty">No validation-rule findings yet. Run authority checks from the Overview tab to populate this list.</p>
            }
            else
            {
                <table class="inspection-table">
                    <thead><tr><th>Rule</th><th>Severity</th><th>Message</th><th>Recorded</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var f in _validationFindings)
                        {
                            var ruleId = CaseDetailFindingsClassifier.ExtractRuleId(f.FindingType);
                            <tr>
                                <td><code>@(ruleId ?? f.FindingType)</code></td>
                                <td><span class="inspection-pill-state is-@f.Severity.ToLowerInvariant()">@f.Severity</span></td>
                                <td>@(string.IsNullOrEmpty(f.Note) ? "—" : f.Note)</td>
                                <td>@f.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(ruleId))
                                    {
                                        <a class="inspection-button" href="/admin/rules/@ruleId">Drill down</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="inspection-card" data-testid="analyst-findings-pane">
            <h3 class="inspection-card-title">Analyst findings (@_analystFindings.Count)</h3>
            @if (!_findingsLoaded) { <p>Loading…</p> }
            else if (_analystFindings.Count == 0)
            {
                <p class="inspection-empty">No findings recorded yet. The image viewer's annotation tool persists findings here.</p>
            }
            else
            {
                <table class="inspection-table">
                    <thead><tr><th>Type</th><th>Severity</th><th>Note</th><th>Location</th><th>Recorded</th></tr></thead>
                    <tbody>
                        @foreach (var f in _analystFindings)
                        {
                            <tr>
                                <td><code>@f.FindingType</code></td>
                                <td><span class="inspection-pill-state is-@f.Severity.ToLowerInvariant()">@f.Severity</span></td>
                                <td>@(string.IsNullOrEmpty(f.Note) ? "—" : f.Note)</td>
                                <td><code>@FormatRoiSummary(f.LocationInImageJson)</code></td>
                                <td>@f.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    };

