@page "/admin/sla"
@* Sprint 31 / B5.1 — SLA dashboard. Reads sla_window via
   SlaDashboardService and renders summary cards, a per-window
   breakdown table, and the top-50 breached drill-in. Vendor-neutral —
   port codes / regime codes are display-only here; the underlying
   data identifiers are vendor-neutral. *@
@attribute [Authorize(Roles = "Inspection.Admin")]
@using NickERP.Inspection.Core.Entities
@using NickERP.Inspection.Web.Services
@using NickERP.Platform.Tenancy
@inject SlaDashboardService Dashboard
@inject ITenantContext Tenant

<PageTitle>SLA dashboard - Inspection v2</PageTitle>

<header class="inspection-page-header">
    <div>
        <h1>SLA dashboard</h1>
        <p class="inspection-page-subtitle">
            Wall-clock SLA windows tracked per case-state transition.
            Open windows recompute live (refresh the page to update);
            closed windows show the historical breach status.
        </p>
    </div>
</header>

@if (!Tenant.IsResolved)
{
    <p class="inspection-empty">Tenant context is not resolved. Sign out and back in.</p>
}
else if (_summary is null)
{
    <p>Loading...</p>
}
else
{
    <section class="inspection-section">
        <div class="inspection-card-grid">
            <div class="inspection-card">
                <h2 class="inspection-card-title">Open</h2>
                <p class="inspection-card-metric">@(_summary.OpenOnTime + _summary.OpenAtRisk + _summary.OpenBreached)</p>
                <ul>
                    <li>On time: @_summary.OpenOnTime</li>
                    <li>At risk: @_summary.OpenAtRisk</li>
                    <li>Breached: @_summary.OpenBreached</li>
                </ul>
            </div>
            <div class="inspection-card">
                <h2 class="inspection-card-title">Closed (7d)</h2>
                <p class="inspection-card-metric">@(_summary.ClosedOnTime + _summary.ClosedBreached)</p>
                <ul>
                    <li>On time: @_summary.ClosedOnTime</li>
                    <li>Breached: @_summary.ClosedBreached</li>
                </ul>
            </div>
            <div class="inspection-card">
                <h2 class="inspection-card-title">Trend (14d)</h2>
                @* Sprint 49 / FU-sla-trend-sparkline — replaces the
                   placeholder with a server-rendered SVG sparkline.
                   Three polylines stack on the same baseline: opened
                   (info), closed (success), breached (danger). Pure
                   server-rendered SVG — no client-side chart library. *@
                @if (_trend is null || _trend.Count == 0)
                {
                    <p class="inspection-empty">No trend data yet.</p>
                }
                else
                {
                    <svg class="inspection-sparkline"
                         viewBox="0 0 @SparkWidth @SparkHeight"
                         preserveAspectRatio="none"
                         role="img"
                         aria-label="14-day trend of opened, closed, and breached SLA windows">
                        <title>14-day SLA trend</title>
                        @if (_breachedPath is not null)
                        {
                            <polyline class="inspection-sparkline-breached"
                                      fill="none"
                                      stroke-width="1.5"
                                      points="@_breachedPath" />
                        }
                        @if (_openedPath is not null)
                        {
                            <polyline class="inspection-sparkline-opened"
                                      fill="none"
                                      stroke-width="1.5"
                                      points="@_openedPath" />
                        }
                        @if (_closedPath is not null)
                        {
                            <polyline class="inspection-sparkline-closed"
                                      fill="none"
                                      stroke-width="1.5"
                                      points="@_closedPath" />
                        }
                    </svg>
                    <ul class="inspection-sparkline-legend">
                        <li><span class="inspection-sparkline-swatch is-opened"></span> Opened (@_trend.Sum(t => t.Opened))</li>
                        <li><span class="inspection-sparkline-swatch is-closed"></span> Closed (@_trend.Sum(t => t.Closed))</li>
                        <li><span class="inspection-sparkline-swatch is-breached"></span> Breached (@_trend.Sum(t => t.Breached))</li>
                    </ul>
                }
            </div>
        </div>
    </section>

    <section class="inspection-section">
        <h2>By queue tier</h2>
        @* Sprint 45 / Phase D — per-tier breakdown cards. Tiers order
           by escalation priority (Urgent first); ManualCount surfaces
           windows that an operator manually assigned (the auto-escalator
           leaves them alone). *@
        @if (_byTier is null || _byTier.Count == 0)
        {
            <p class="inspection-empty">No tier breakdown available yet.</p>
        }
        else
        {
            <div class="inspection-card-grid">
                @foreach (var t in _byTier)
                {
                    <div class="inspection-card">
                        <h2 class="inspection-card-title">@t.Tier</h2>
                        <p class="inspection-card-metric">@(t.OpenOnTime + t.OpenAtRisk + t.OpenBreached)</p>
                        <ul>
                            <li>On time: @t.OpenOnTime</li>
                            <li>At risk: @t.OpenAtRisk</li>
                            <li>Breached: @t.OpenBreached</li>
                            <li>Manual: @t.ManualCount</li>
                        </ul>
                    </div>
                }
            </div>
        }
    </section>

    <section class="inspection-section">
        <h2>Reclassify a window</h2>
        @* Sprint 45 / Phase D — manual reclassify. Operator pastes the
           SlaWindow id from the breach drill-in table + picks a tier;
           saving sets QueueTierIsManual=true so the escalator worker
           leaves it alone. *@
        <div class="inspection-form">
            <label>SLA window id <input type="text" @bind="_reclassifyId" /></label>
            <label>Tier
                <select @bind="_reclassifyTier">
                    @foreach (var tier in Enum.GetValues<QueueTier>())
                    {
                        <option value="@tier">@tier</option>
                    }
                </select>
            </label>
            <button class="btn btn-primary" type="button" @onclick="ReclassifyAsync"
                    disabled="@(!CanReclassify())">Reclassify</button>
            @if (!string.IsNullOrEmpty(_reclassifyMessage))
            {
                <p class="@(_reclassifySuccess ? "inspection-success" : "inspection-error")">
                    @_reclassifyMessage
                </p>
            }
        </div>
    </section>

    <section class="inspection-section">
        <h2>By window</h2>
        @if (_summary.ByWindow.Count == 0)
        {
            <p class="inspection-empty">No SLA windows have been recorded yet.</p>
        }
        else
        {
            <table class="inspection-table">
                <thead>
                    <tr>
                        <th>Window</th>
                        <th>Open: on-time</th>
                        <th>Open: at-risk</th>
                        <th>Open: breached</th>
                        <th>Closed: on-time</th>
                        <th>Closed: breached</th>
                        <th>Avg duration (min)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in _summary.ByWindow)
                    {
                        <tr>
                            <td><code>@b.WindowName</code></td>
                            <td>@b.OpenOnTime</td>
                            <td>@b.OpenAtRisk</td>
                            <td>@b.OpenBreached</td>
                            <td>@b.ClosedOnTime</td>
                            <td>@b.ClosedBreached</td>
                            <td>@(b.AverageDurationMinutes is null ? "-" : b.AverageDurationMinutes.Value.ToString("0.0"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="inspection-section">
        <h2>Top breaches</h2>
        @if (_breached is null || _breached.Count == 0)
        {
            <p class="inspection-empty">No breached windows. Either everything is on time or there is no SLA traffic yet.</p>
        }
        else
        {
            <table class="inspection-table">
                <thead>
                    <tr>
                        <th>Case</th>
                        <th>Window</th>
                        <th>Started</th>
                        <th>Due</th>
                        <th>Closed</th>
                        <th>Budget (min)</th>
                        <th>Over (min)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _breached)
                    {
                        <tr>
                            <td><a href="/cases/@r.CaseId">@r.CaseId.ToString().Substring(0, 8)</a></td>
                            <td><code>@r.WindowName</code></td>
                            <td>@r.StartedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@r.DueAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(r.ClosedAt is null ? "open" : r.ClosedAt.Value.ToString("yyyy-MM-dd HH:mm"))</td>
                            <td>@r.BudgetMinutes</td>
                            <td>@r.MinutesOver.ToString("0.0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private SlaDashboardSummary? _summary;
    private List<SlaBreachedRow>? _breached;
    // Sprint 45 / Phase D — per-tier breakdown + reclassify form state.
    private List<SlaTierBreakdown>? _byTier;
    private string _reclassifyId = string.Empty;
    private QueueTier _reclassifyTier = QueueTier.Standard;
    private string? _reclassifyMessage;
    private bool _reclassifySuccess;

    // Sprint 49 / FU-sla-trend-sparkline — trend buckets + the SVG
    // path strings derived from them. Recomputed on every reload.
    private List<SlaTrendBucket>? _trend;
    private string? _openedPath;
    private string? _closedPath;
    private string? _breachedPath;
    private const int SparkWidth = 200;
    private const int SparkHeight = 50;

    protected override async Task OnInitializedAsync()
    {
        if (!Tenant.IsResolved) return;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _summary = await Dashboard.BuildSummaryAsync();
        _breached = (await Dashboard.ListBreachedAsync()).ToList();
        _byTier = (await Dashboard.ListByTierAsync()).ToList();
        _trend = (await Dashboard.GetTrendAsync()).ToList();
        BuildSparklinePaths();
    }

    /// <summary>
    /// Sprint 49 / FU-sla-trend-sparkline — derive three SVG polyline
    /// "points" strings from the trend buckets. All three series share
    /// the same vertical scale (max-of-all-three) so the relative
    /// magnitudes read correctly. With zero data on every day we emit
    /// flat baselines at the chart bottom.
    /// </summary>
    private void BuildSparklinePaths()
    {
        if (_trend is null || _trend.Count == 0)
        {
            _openedPath = _closedPath = _breachedPath = null;
            return;
        }

        var maxValue = Math.Max(1, _trend.Max(t => Math.Max(t.Opened, Math.Max(t.Closed, t.Breached))));
        // Pad to leave 2px on top/bottom so strokes don't clip.
        var top = 2;
        var bottom = SparkHeight - 2;
        var span = bottom - top;

        string PathFor(System.Func<SlaTrendBucket, int> selector)
        {
            // Distribute points evenly across the viewBox width.
            var n = _trend.Count;
            var stepX = n > 1 ? (double)SparkWidth / (n - 1) : 0;
            var sb = new System.Text.StringBuilder();
            for (var i = 0; i < n; i++)
            {
                var v = selector(_trend[i]);
                var y = bottom - (span * v / (double)maxValue);
                var x = i * stepX;
                if (i > 0) sb.Append(' ');
                sb.Append(System.FormattableString.Invariant($"{x:0.##},{y:0.##}"));
            }
            return sb.ToString();
        }

        _openedPath = PathFor(t => t.Opened);
        _closedPath = PathFor(t => t.Closed);
        _breachedPath = PathFor(t => t.Breached);
    }

    private bool CanReclassify() =>
        !string.IsNullOrWhiteSpace(_reclassifyId)
        && Guid.TryParse(_reclassifyId, out _);

    private async Task ReclassifyAsync()
    {
        if (!Guid.TryParse(_reclassifyId, out var id))
        {
            _reclassifyMessage = "Invalid window id (expected a GUID).";
            _reclassifySuccess = false;
            return;
        }
        var ok = await Dashboard.ReclassifyTierAsync(id, _reclassifyTier);
        _reclassifySuccess = ok;
        _reclassifyMessage = ok
            ? $"Reclassified {id} to {_reclassifyTier} (manual)."
            : $"No SLA window found for id {id}.";
        if (ok)
        {
            _reclassifyId = string.Empty;
            await ReloadAsync();
        }
    }
}
