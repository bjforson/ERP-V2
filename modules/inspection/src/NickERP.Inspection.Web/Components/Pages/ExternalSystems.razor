@page "/external-systems"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using NickERP.Inspection.Application.ExternalSystems
@using NickERP.Inspection.Core.Entities
@using NickERP.Inspection.Database
@using NickERP.Inspection.ExternalSystems.Abstractions
@using NickERP.Platform.Plugins
@using NickERP.Platform.Tenancy
@inject InspectionDbContext Db
@inject ExternalSystemAdminService Admin
@inject IPluginRegistry Plugins
@inject ITenantContext Tenant

<PageTitle>External systems — Inspection v2</PageTitle>

<header class="inspection-page-header">
    <div>
        <h1>External systems</h1>
        <p class="inspection-page-subtitle">Authorities you fetch documents from and submit verdicts to (ICUMS, GRA, etc.).</p>
    </div>
</header>

<section class="inspection-section">
    <div class="inspection-card">
        <h2 class="inspection-card-title">Register external system</h2>
        <EditForm Model="_form" OnValidSubmit="CreateAsync" FormName="add-external" class="inspection-form">
            <div class="inspection-form-row">
                <label>
                    <span>Plugin</span>
                    <InputSelect class="inspection-input" @bind-Value="_form.TypeCode">
                        <option value="">— pick a plugin —</option>
                        @foreach (var p in _externalPlugins)
                        {
                            <option value="@p.TypeCode">@p.TypeCode — @p.Manifest.DisplayName (v@(p.Manifest.Version))</option>
                        }
                    </InputSelect>
                </label>
                <label><span>Display name</span><InputText class="inspection-input" @bind-Value="_form.DisplayName" placeholder="ICUMS Tema endpoint" /></label>
                <label>
                    <span>Scope</span>
                    <InputSelect class="inspection-input" @bind-Value="_form.Scope">
                        <option value="@ExternalSystemBindingScope.PerLocation">Per-location (one location)</option>
                        <option value="@ExternalSystemBindingScope.SubsetOfLocations">Subset of locations (two or more)</option>
                        <option value="@ExternalSystemBindingScope.Shared">Shared (every location in tenant)</option>
                    </InputSelect>
                </label>
            </div>

            @if (_form.Scope is ExternalSystemBindingScope.PerLocation or ExternalSystemBindingScope.SubsetOfLocations)
            {
                <div class="inspection-form-row">
                    <fieldset class="inspection-fieldset">
                        <legend>
                            @if (_form.Scope == ExternalSystemBindingScope.PerLocation)
                            {
                                <span>Pick exactly one location</span>
                            }
                            else
                            {
                                <span>Pick two or more locations</span>
                            }
                        </legend>
                        @if (_locations.Count == 0)
                        {
                            <p class="inspection-empty">No locations exist yet — set one up before binding an external system.</p>
                        }
                        else
                        {
                            @foreach (var loc in _locations)
                            {
                                var locId = loc.Id;
                                var isChecked = _form.SelectedLocationIds.Contains(locId);
                                <label class="inspection-checkbox-label">
                                    <input type="checkbox" name="locationIds" value="@locId" checked="@isChecked"
                                           @onchange="e => ToggleLocation(locId, e.Value as bool? ?? false)" />
                                    <span>@loc.Name</span>
                                </label>
                            }
                        }
                    </fieldset>
                </div>
            }

            <div class="inspection-form-actions">
                <button type="submit" class="inspection-button inspection-button-primary">Register</button>
                @if (!string.IsNullOrEmpty(_message)) { <span class="inspection-form-message">@_message</span> }
            </div>
        </EditForm>
    </div>

    @if (_rows is null) { <p>Loading…</p> }
    else if (_rows.Count == 0) { <p class="inspection-empty">No external systems yet.</p> }
    else
    {
        <table class="inspection-table">
            <thead><tr><th>Plugin</th><th>Display name</th><th>Scope</th><th>Bindings</th><th>Active</th><th>Created</th></tr></thead>
            <tbody>
                @foreach (var r in _rows)
                {
                    <tr>
                        <td><code>@r.TypeCode</code></td>
                        <td>@r.DisplayName</td>
                        <td>@DescribeScope(r.Scope)</td>
                        <td>@r.Bindings.Count</td>
                        <td>@(r.IsActive ? "active" : "inactive")</td>
                        <td>@r.CreatedAt.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<ExternalSystemInstance>? _rows;
    private List<RegisteredPlugin> _externalPlugins = new();
    private List<Location> _locations = new();
    private string _message = string.Empty;

    [SupplyParameterFromForm] private ExternalForm _form { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        _externalPlugins = Plugins.ForContract(typeof(IExternalSystemAdapter)).ToList();
        await Reload();
    }

    private async Task Reload()
    {
        _rows = await Db.ExternalSystemInstances.AsNoTracking()
            .Include(e => e.Bindings)
            .OrderBy(x => x.DisplayName)
            .ToListAsync();
        _locations = await Db.Locations.AsNoTracking()
            .OrderBy(l => l.Name)
            .ToListAsync();
    }

    private void ToggleLocation(Guid locationId, bool selected)
    {
        if (selected)
        {
            if (!_form.SelectedLocationIds.Contains(locationId))
            {
                _form.SelectedLocationIds.Add(locationId);
            }
        }
        else
        {
            _form.SelectedLocationIds.Remove(locationId);
        }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.TypeCode) || string.IsNullOrWhiteSpace(_form.DisplayName))
        {
            _message = "Plugin and display name are required."; return;
        }
        // Phase F1 — fail loud instead of silently coercing to tenant 1.
        if (!Tenant.IsResolved)
        {
            _message = "Tenant context is not resolved. Sign out and back in.";
            return;
        }

        // Sprint 16 — admin service centralises per-scope validation +
        // binding writes; we surface ArgumentException messages back to
        // the form. Shared scope drops bindings; per-location/subset use
        // whatever the user ticked.
        var ids = _form.Scope == ExternalSystemBindingScope.Shared
            ? Array.Empty<Guid>()
            : _form.SelectedLocationIds.Distinct().ToArray();

        try
        {
            await Admin.RegisterAsync(
                _form.TypeCode,
                _form.DisplayName,
                description: null,
                _form.Scope,
                ids);
            _form = new ExternalForm();
            _message = "Registered.";
            await Reload();
        }
        catch (ArgumentException ex)
        {
            _message = ex.Message;
        }
    }

    private static string DescribeScope(ExternalSystemBindingScope scope) => scope switch
    {
        ExternalSystemBindingScope.PerLocation => "Per-location",
        ExternalSystemBindingScope.SubsetOfLocations => "Subset",
        ExternalSystemBindingScope.Shared => "Shared",
        _ => scope.ToString()
    };

    public sealed class ExternalForm
    {
        public string TypeCode { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public ExternalSystemBindingScope Scope { get; set; } = ExternalSystemBindingScope.PerLocation;
        public List<Guid> SelectedLocationIds { get; set; } = new();
    }
}
