{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "NickErp": {
    "Identity": {
      "CfAccess": {
        "TeamDomain": "nickscan",
        "ApplicationAudience": "dev-bypass-not-validated-locally",
        "DevBypass": {
          "Enabled": true,
          "FakeUserEmail": "dev@nickscan.com",
          "TriggerHeader": "X-Dev-User"
        }
      }
    },
    "Inspection": {
      "Imaging": {
        "StorageRoot": "C:\\Shared\\ERP V2\\.imaging-store",
        "WorkerPollIntervalSeconds": 3,
        "WorkerBatchSize": 16
      }
    }
  }
}
