<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>NickERP.Inspection.Authorities.Abstractions</RootNamespace>
    <AssemblyName>NickERP.Inspection.Authorities.Abstractions</AssemblyName>
    <Description>NickERP Inspection v2 — IAuthorityRulesProvider contract. Country/authority-specific rule packs (CustomsGh, etc.) implement this; e.g. port-match, regime-validation, CMR→IM upgrade rules from v1 land here as a CustomsGh implementation.</Description>
    <Version>0.1.0</Version>
    <Company>Nick TC-Scan Ltd</Company>
    <Product>NICKSCAN ERP SOLUTION</Product>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\platform\NickERP.Platform.Plugins\NickERP.Platform.Plugins.csproj" />
  </ItemGroup>

  <!--
    Stamp this Abstractions assembly with a [ContractVersion]. Currently 1.1
    because InspectionCaseData was extended this session with the Scans
    field (IReadOnlyList<ScanSnapshot>) — an additive change. Plugins that
    rely on Scans (e.g. gh-customs) declare minHostContractVersion "1.1".
    Bump major on breaking changes; bump minor on additive changes.
  -->
  <ItemGroup>
    <AssemblyAttribute Include="NickERP.Platform.Plugins.ContractVersionAttribute">
      <_Parameter1>1.1</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
