<Project Sdk="Microsoft.NET.Sdk">

  <!--
    OcrSmokeTest — proves the §6.1 container-OCR contract chain end-to-end
    against the random-init container-OCR stub artifact produced by
    tools/inference-training/container-ocr/train_stub_ocr.py. Loads
    model.onnx via the OnnxRuntime runner (sha256 fail-fast included),
    builds a synthetic plate ROI, runs IContainerNumberRecognizer.RecognizeAsync,
    and verifies the output shape + that the ISO 6346 check-digit gate
    fires on known-bad inputs (string-level test).

    Not a unit test — a console exe that writes its own report. Sits under
    modules/inspection/tools/ alongside InferenceSmokeTest, the contract
    it exercises.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>NickERP.Inspection.Tools.OcrSmokeTest</RootNamespace>
    <AssemblyName>NickERP.Inspection.Tools.OcrSmokeTest</AssemblyName>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.0" />
    <!-- Bumped 3.1.10 -> 3.1.11 (Sprint 32 FU-A) for GHSA-rxmq-m78w-7wmc. -->
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.11" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\NickERP.Inspection.Inference.Abstractions\NickERP.Inspection.Inference.Abstractions.csproj" />
    <ProjectReference Include="..\..\plugins\NickERP.Inspection.Inference.OnnxRuntime\NickERP.Inspection.Inference.OnnxRuntime.csproj" />
    <ProjectReference Include="..\..\plugins\NickERP.Inspection.Inference.OCR.ContainerNumber\NickERP.Inspection.Inference.OCR.ContainerNumber.csproj" />
  </ItemGroup>

</Project>
