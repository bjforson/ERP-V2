<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>NickERP.Platform.Plugins.Demos.MockEcho</RootNamespace>
    <AssemblyName>NickERP.Platform.Plugins.Demos.MockEcho</AssemblyName>
    <Description>Reference plugin for ROADMAP A.4.4 — proves the [Plugin] attribute + manifest + loader round-trip works. Throwaway demo. Drops a DLL + plugin.json into a host's plugins folder and the host can resolve `IEchoPlugin` by TypeCode "mock-echo".</Description>
    <IsPackable>false</IsPackable>

    <!-- Copy plugin.json next to the built DLL so the loader finds it via the
         {dllname}.plugin.json convention. Use a typed file name so multiple
         plugins can coexist in one plugins folder. -->
  </PropertyGroup>

  <ItemGroup>
    <None Update="plugin.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\NickERP.Platform.Plugins\NickERP.Platform.Plugins.csproj" />
  </ItemGroup>

</Project>
