@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
            <NotAuthorized>
                <LayoutView Layout="typeof(MainLayout)">
                    <h2>Sign-in required</h2>
                    <p>This demo requires a Cloudflare Access session, or — in Development — the
                       <code>X-Dev-User</code> header.</p>
                    <p>If you are running locally and the dev bypass is enabled, attach
                       <code>X-Dev-User: dev@nickscan.com</code> to your request and reload.</p>
                </LayoutView>
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
