<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    <RootNamespace>NickERP.Portal</RootNamespace>
    <AssemblyName>NickERP.Portal</AssemblyName>
    <Description>NickERP Portal v2 — suite landing page. Live stats from the platform, audit log search, tenants admin, health rollup, and the AppSwitcher hub. Runs on the new platform stack (Identity / Tenancy / Audit / Web.Shared) end-to-end.</Description>
    <Version>0.1.0</Version>
    <Company>Nick TC-Scan Ltd</Company>
    <Product>NICKSCAN ERP SOLUTION</Product>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\platform\NickERP.Platform.Logging\NickERP.Platform.Logging.csproj" />
    <ProjectReference Include="..\..\platform\NickERP.Platform.Telemetry\NickERP.Platform.Telemetry.csproj" />
    <ProjectReference Include="..\..\platform\NickERP.Platform.Identity\NickERP.Platform.Identity.csproj" />
    <ProjectReference Include="..\..\platform\NickERP.Platform.Identity.Database\NickERP.Platform.Identity.Database.csproj" />
    <ProjectReference Include="..\..\platform\NickERP.Platform.Tenancy\NickERP.Platform.Tenancy.csproj" />
    <ProjectReference Include="..\..\platform\NickERP.Platform.Tenancy.Database\NickERP.Platform.Tenancy.Database.csproj" />
    <ProjectReference Include="..\..\platform\NickERP.Platform.Audit\NickERP.Platform.Audit.csproj" />
    <ProjectReference Include="..\..\platform\NickERP.Platform.Audit.Database\NickERP.Platform.Audit.Database.csproj" />
    <ProjectReference Include="..\..\platform\NickERP.Platform.Web.Shared\NickERP.Platform.Web.Shared.csproj" />
    <!-- G2 — NickFinance pathfinder. Program.cs guards on
         ConnectionStrings:NickFinance and skips registration if absent. -->
    <ProjectReference Include="..\..\modules\nickfinance\src\NickERP.NickFinance.Core\NickERP.NickFinance.Core.csproj" />
    <ProjectReference Include="..\..\modules\nickfinance\src\NickERP.NickFinance.Database\NickERP.NickFinance.Database.csproj" />
    <ProjectReference Include="..\..\modules\nickfinance\src\NickERP.NickFinance.Web\NickERP.NickFinance.Web.csproj" />
    <!-- Sprint 14 / VP6 Phase A.5 — Tenants.razor calls
         IAnalysisServiceBootstrap.EnsureAllLocationsServiceAsync after
         creating a new tenant so the un-deletable "All Locations" service
         exists for it. The bootstrap writes against InspectionDbContext;
         hence the Core + Database + Application references here. -->
    <ProjectReference Include="..\..\modules\inspection\src\NickERP.Inspection.Core\NickERP.Inspection.Core.csproj" />
    <ProjectReference Include="..\..\modules\inspection\src\NickERP.Inspection.Database\NickERP.Inspection.Database.csproj" />
    <ProjectReference Include="..\..\modules\inspection\src\NickERP.Inspection.Application\NickERP.Inspection.Application.csproj" />
  </ItemGroup>

</Project>
