@*
 * AppCard — one entry in the home page's apps grid.
 *@

@if (Disabled)
{
    <div class="portal-app-card portal-app-card-disabled">
        <div class="portal-app-card-mark" style="background: @Color">@Initial</div>
        <div class="portal-app-card-text">
            <div class="portal-app-card-title">@Title</div>
            <div class="portal-app-card-desc">@Description</div>
        </div>
        <span class="portal-pill is-coming-soon">Soon</span>
    </div>
}
else
{
    <a class="portal-app-card" href="@Href">
        <div class="portal-app-card-mark" style="background: @Color">@Initial</div>
        <div class="portal-app-card-text">
            <div class="portal-app-card-title">@Title</div>
            <div class="portal-app-card-desc">@Description</div>
        </div>
    </a>
}

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string Href { get; set; } = "#";
    [Parameter] public string Color { get; set; } = "var(--nickerp-color-primary)";
    [Parameter] public string Initial { get; set; } = "?";
    [Parameter] public bool Disabled { get; set; }
}
