@page "/"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using NickERP.Platform.Audit.Database
@using NickERP.Platform.Identity.Database
@using NickERP.Platform.Tenancy
@using NickERP.Platform.Tenancy.Database
@using NickERP.Portal.Services.Modules
@inject IdentityDbContext Identity
@inject TenancyDbContext Tenancy
@inject AuditDbContext Audit
@inject NickERP.Portal.Services.NickFinanceFeatureFlag NickFinance
@inject IModuleRegistry ModuleRegistry
@inject ITenantContext TenantCtx

<PageTitle>NickERP Portal</PageTitle>

<header class="portal-page-header">
    <div>
        <h1>Welcome back<AuthorizeView Context="auth">, <span class="portal-page-greeting">@auth.User.FindFirst("nickerp:display_name")?.Value</span></AuthorizeView></h1>
        <p class="portal-page-subtitle">One pane for the whole NickERP suite.</p>
    </div>
</header>

<section class="portal-stats">
    <StatTile Label="Tenants" Value="@_tenantCount" Color="var(--nickerp-color-primary)" Href="/tenants" />
    <StatTile Label="Users" Value="@_userCount" Color="var(--nickerp-color-accent)" />
    <StatTile Label="App scopes" Value="@_scopeCount" Color="#7c3aed" />
    <StatTile Label="Audit events" Value="@_eventCount" Color="#16a34a" Href="/audit" />
</section>

<section class="portal-section">
    <h2>v2 modules</h2>
    @* Sprint 29 — module tiles flow through IModuleRegistry so per-tenant
       overrides apply. Comms placeholder retained as a portal-local
       reminder of the v1-shimmed module. *@
    <div class="portal-app-grid">
        @if (_modules is not null)
        {
            @foreach (var m in _modules)
            {
                <AppCard Title="@m.DisplayName"
                         Description="@m.Description"
                         Href="@m.BaseUrl"
                         Color="@m.Color"
                         Initial="@m.IconHint" />
            }
        }
        @if (NickFinance.Enabled)
        {
            <AppCard Title="Petty Cash" Description="NickFinance G2 pathfinder (portal-local)" Href="/finance/petty-cash/boxes" Color="#16a34a" Initial="F" />
        }
        <AppCard Title="Comms v2" Description="Adapted from v1, not rebuilt" Href="#" Color="#06b6d4" Initial="C" Disabled="true" />
    </div>
    <p class="portal-page-subtitle">
        <a href="/launcher">Open the dedicated launcher &rarr;</a>
    </p>
</section>

<section class="portal-section">
    <h2>Platform tools</h2>
    <div class="portal-app-grid">
        <AppCard Title="Tenants" Description="Tenancy admin" Href="/tenants" Color="var(--nickerp-color-primary)" Initial="T" />
        <AppCard Title="Edge keys" Description="Per-edge-node API keys (issue + revoke)" Href="/edge-keys" Color="#0ea5e9" Initial="E" />
        <AppCard Title="Audit log" Description="Every event across the suite" Href="/audit" Color="#dc2626" Initial="A" />
        <AppCard Title="Health" Description="Service status rollup" Href="/health" Color="#475569" Initial="?" />
        <AppCard Title="Sprint" Description="Active sprint + history + backlog" Href="/sprint" Color="#7c3aed" Initial="◆" />
        <AppCard Title="Seq" Description="Centralized logs + traces" Href="http://localhost:5341" Color="#0f172a" Initial="S" />
    </div>
</section>

@code {
    private long _tenantCount;
    private long _userCount;
    private long _scopeCount;
    private long _eventCount;
    private IReadOnlyList<ModuleRegistryEntry>? _modules;

    protected override async Task OnInitializedAsync()
    {
        // Best-effort — surface zeros if any of the three DBs is unreachable rather than blowing up the home page.
        try { _tenantCount = await Tenancy.Tenants.LongCountAsync(); } catch { _tenantCount = 0; }
        try { _userCount = await Identity.Users.LongCountAsync(); } catch { _userCount = 0; }
        try { _scopeCount = await Identity.AppScopes.LongCountAsync(); } catch { _scopeCount = 0; }
        try { _eventCount = await Audit.Events.LongCountAsync(); } catch { _eventCount = 0; }

        // Sprint 29 — module tiles via the registry. Same best-effort
        // pattern as the count probes: empty list ⇒ render no tiles
        // rather than blowing up the home page.
        try
        {
            var tenantId = TenantCtx.IsResolved
                ? TenantCtx.TenantId
                : NickERP.Platform.Tenancy.Entities.Tenant.DefaultTenantId;
            _modules = await ModuleRegistry.GetModulesForTenantAsync(tenantId);
        }
        catch
        {
            _modules = Array.Empty<ModuleRegistryEntry>();
        }
    }
}
