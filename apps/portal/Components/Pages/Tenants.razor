@page "/tenants"
@attribute [Authorize]
@using System.Text.Json
@using Microsoft.EntityFrameworkCore
@using NickERP.Inspection.Application.AnalysisServices
@using NickERP.Platform.Audit.Events
@using NickERP.Platform.Tenancy
@using NickERP.Platform.Tenancy.Database
@using NickERP.Platform.Tenancy.Entities
@using NickERP.Portal.Services
@inject TenancyDbContext Db
@inject IEventPublisher Publisher
@inject ITenantContext TenantCtx
@inject AuthenticationStateProvider AuthState
@inject IServiceProvider Sp
@inject InspectionFeatureFlag InspectionFlag
@inject ILogger<Tenants> Logger

<PageTitle>Tenants — NickERP Portal</PageTitle>

<header class="portal-page-header">
    <div>
        <h1>Tenants</h1>
        <p class="portal-page-subtitle">One row per isolated platform deployment.</p>
    </div>
</header>

<section class="portal-section">
    <div class="portal-card">
        <h2 class="portal-card-title">Add tenant</h2>
        <EditForm Model="_form" OnValidSubmit="CreateAsync" FormName="add-tenant" class="portal-form">
            <div class="portal-form-row">
                <label>
                    <span>Code</span>
                    <InputText class="portal-input" @bind-Value="_form.Code" placeholder="my-customer" />
                </label>
                <label>
                    <span>Name</span>
                    <InputText class="portal-input" @bind-Value="_form.Name" placeholder="My Customer Ltd" />
                </label>
                <label>
                    <span>Currency</span>
                    <InputText class="portal-input" @bind-Value="_form.Currency" placeholder="GHS" />
                </label>
                <label>
                    <span>Time zone</span>
                    <InputText class="portal-input" @bind-Value="_form.TimeZone" placeholder="Africa/Accra" />
                </label>
            </div>
            <div class="portal-form-actions">
                <button type="submit" class="portal-button portal-button-primary">Create</button>
                @if (!string.IsNullOrEmpty(_message))
                {
                    <span class="portal-form-message">@_message</span>
                }
            </div>
        </EditForm>
    </div>

    @if (_tenants is null)
    {
        <p>Loading…</p>
    }
    else
    {
        <table class="portal-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Plan</th>
                    <th>TZ</th>
                    <th>Currency</th>
                    <th>State</th>
                    <th>Visibility</th>
                    <th>Multi-svc</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in _tenants)
                {
                    <tr>
                        <td>@t.Id</td>
                        <td><code>@t.Code</code></td>
                        <td>@t.Name</td>
                        <td>@t.BillingPlan</td>
                        <td>@t.TimeZone</td>
                        <td>@t.Currency</td>
                        <td>
                            <span class="portal-state-badge portal-state-@(t.State.ToString().ToLowerInvariant())">@t.State</span>
                        </td>
                        <td>@t.CaseVisibilityModel</td>
                        <td>@(t.AllowMultiServiceMembership ? "yes" : "no")</td>
                        <td>@t.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td><a class="portal-button" href="/tenants/@t.Id">Settings</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<Tenant>? _tenants;
    private string _message = string.Empty;

    [SupplyParameterFromForm]
    private TenantForm _form { get; set; } = new();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        // Sprint 18 — admin must see SoftDeleted + PendingHardPurge tenants
        // alongside Active/Suspended; the global query filter on
        // TenancyDbContext hides the deleted-but-retained ones from
        // business code, but the tenants admin page is exactly the place
        // those need to surface.
        _tenants = await Db.Tenants.IgnoreQueryFilters().AsNoTracking().OrderBy(t => t.Id).ToListAsync();
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Code) || string.IsNullOrWhiteSpace(_form.Name))
        {
            _message = "Code and Name are required.";
            return;
        }

        var existing = await Db.Tenants.FirstOrDefaultAsync(t => t.Code == _form.Code);
        if (existing is not null)
        {
            _message = $"A tenant with code '{_form.Code}' already exists.";
            return;
        }

        var t = new Tenant
        {
            Code = _form.Code.Trim(),
            Name = _form.Name.Trim(),
            BillingPlan = string.IsNullOrWhiteSpace(_form.BillingPlan) ? "internal" : _form.BillingPlan.Trim(),
            TimeZone = string.IsNullOrWhiteSpace(_form.TimeZone) ? "Africa/Accra" : _form.TimeZone.Trim(),
            Locale = "en-GH",
            Currency = string.IsNullOrWhiteSpace(_form.Currency) ? "GHS" : _form.Currency.Trim().ToUpperInvariant(),
            State = TenantState.Active,
            CreatedAt = DateTimeOffset.UtcNow
        };

        Db.Tenants.Add(t);
        await Db.SaveChangesAsync();

        // Sprint 14 / VP6 Phase A.5 — bootstrap the immutable "All
        // Locations" AnalysisService for the new tenant. Skipped silently
        // when the inspection module is not wired on this portal host
        // (ConnectionStrings:Inspection unset). Best-effort: a failure
        // here logs but does not roll back the tenant create — operator
        // can re-run via the bootstrap admin endpoint (TBD) or by
        // restarting the host with the connection set, since
        // EnsureAllLocationsServiceAsync is idempotent.
        if (InspectionFlag.Enabled)
        {
            try
            {
                var auth2 = await AuthState.GetAuthenticationStateAsync();
                var actorIdRaw2 = auth2.User?.FindFirst("nickerp:id")?.Value;
                Guid? actorId2 = Guid.TryParse(actorIdRaw2, out var g2) ? g2 : null;

                using var scope = Sp.CreateScope();
                var bootstrap = scope.ServiceProvider
                    .GetRequiredService<IAnalysisServiceBootstrap>();
                // The bootstrap impl calls SetTenant(t.Id) internally so
                // app.tenant_id is pushed for the inspection-side INSERT
                // independent of this request's caller-tenant context.
                await bootstrap.EnsureAllLocationsServiceAsync(t.Id, actorId2);
            }
            catch (Exception bex)
            {
                Logger.LogWarning(bex,
                    "VP6 bootstrap of All Locations service failed for new tenant {TenantId}; "
                    + "tenant create succeeded. EnsureAllLocationsServiceAsync is idempotent — "
                    + "fix-forward by re-invoking it once the inspection DB is reachable.",
                    t.Id);
            }
        }

        // Emit a domain event so the audit log lights up.
        await EmitTenantCreatedEventAsync(t);

        _form = new TenantForm();
        _message = $"Created tenant {t.Code} (id {t.Id}).";
        await Reload();
    }

    private async Task EmitTenantCreatedEventAsync(Tenant t)
    {
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var actorIdRaw = auth.User?.FindFirst("nickerp:id")?.Value;
            Guid? actorId = Guid.TryParse(actorIdRaw, out var g) ? g : null;
            var tenantClaim = auth.User?.FindFirst("nickerp:tenant_id")?.Value;
            long callerTenant = long.TryParse(tenantClaim, out var ct) ? ct : (TenantCtx.IsResolved ? TenantCtx.TenantId : 1);

            var payload = JsonSerializer.SerializeToElement(new { t.Id, t.Code, t.Name, t.Currency, t.TimeZone });
            var evt = DomainEvent.Create(
                tenantId: callerTenant,
                actorUserId: actorId,
                correlationId: System.Diagnostics.Activity.Current?.RootId,
                eventType: "nickerp.tenancy.tenant_created",
                entityType: "Tenant",
                entityId: t.Id.ToString(),
                payload: payload,
                idempotencyKey: NickERP.Platform.Audit.IdempotencyKey.ForEntityChange(
                    callerTenant, "nickerp.tenancy.tenant_created", "Tenant", t.Id.ToString(), DateTimeOffset.UtcNow));
            await Publisher.PublishAsync(evt);
        }
        catch
        {
            // Audit emission is best-effort — don't fail the user-facing create on this.
        }
    }

    public sealed class TenantForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string BillingPlan { get; set; } = "internal";
        public string TimeZone { get; set; } = "Africa/Accra";
        public string Currency { get; set; } = "GHS";
    }
}
