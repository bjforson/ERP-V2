# =====================================================================
# NickERP.Inspection v2 — .gitignore
# Standard .NET ignore + plugin-runtime drop folder.
# Phase 6.0 will add language-specific exclusions as needed.
# =====================================================================

# Build output
bin/
obj/
out/
artifacts/
publish/
*.dll
*.exe
*.pdb

# IDE / editor
.vs/
.vscode/
.idea/
*.user
*.suo
*.userprefs
*.swp
*~

# Test output
TestResults/
[Tt]est[Rr]esult*/
coverage*.xml
coverage*.json
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Logs / local state
*.log
logs/
*.local.json

# Plugin runtime drop folder — adapter DLLs land here at deploy, not in source
plugins/*.dll
plugins/*.pdb
!plugins/README.md

# Secrets — should never be committed
*.pfx
*.key
appsettings.*.local.json
secrets.json
.env
.env.*
!.env.example

# EF Core temp
*.efcache

# Inspection v2 host plugins folder — populated from build output by deploy/CI scripts, not source-tracked.
modules/inspection/src/NickERP.Inspection.Web/plugins/

# Local-machine test fixtures (synthetic ICUMS batches, FS6000 scan sets, etc.)
.test/

# Local-machine pre-render store (sources + rendered thumbnails/previews) — populated at runtime, not source-tracked.
.imaging-store/

# Python tooling under tools/ — Sprint 12 image-analysis scaffolds.
# Source-track .py / .md / requirements.txt / configs; ignore venvs,
# bytecode, harvested training data, and ONNX weight blobs.
tools/**/.venv/
tools/**/__pycache__/
*.pyc
tools/inference-training/container-split/data/
tools/inference-training/container-ocr/data/
tools/inference-training/**/runs/
tools/inference-training/**/checkpoints/

# storage/ holds stub ONNX exports landed by Sprint 12 as design
# artifacts. The .onnx graph files (small, document input/output
# shape) are source-tracked; the .onnx.data weight blobs (~55MB each,
# regenerable from a 1-epoch training run on 88 samples) are not.
storage/**/*.onnx.data

# Worktrees for parallel sprint masters — never tracked
.worktrees/

# Generated migration scripts — operator-applied, not source-tracked
tools/migrations/*.sql

# External design docs ingested as reference material
*.docx
